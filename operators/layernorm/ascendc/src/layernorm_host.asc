#include <cstdint>
#include <iostream>
#include <vector>
#include <string>
#include <chrono>
#include <algorithm>
#include <cmath>
#include <cstring>
#include "acl/acl.h"
#include "layernorm_tiling.h"
#include "data_utils.h"

struct BenchResult {
    double median_us, mean_us, min_us, p90_us, std_us;
    std::vector<double> latencies_us;
};

#include "layernorm_kernel.asc"

BenchResult measure_kernel_only(uint32_t blockNum, aclrtStream stream,
    void *inputDevice, void *weightDevice, void *biasDevice,
    void *outputDevice, void *tilingDevice,
    int warmup, int loops, int repeat)
{
    for (int i = 0; i < warmup; i++)
        layernorm_kernel<<<blockNum, nullptr, stream>>>((GM_ADDR)inputDevice, (GM_ADDR)weightDevice, (GM_ADDR)biasDevice, (GM_ADDR)outputDevice, (GM_ADDR)tilingDevice);
    aclrtSynchronizeStream(stream);

    aclrtEvent start, stop;
    aclrtCreateEvent(&start); aclrtCreateEvent(&stop);

    std::vector<double> latencies;
    for (int r = 0; r < repeat; r++) {
        aclrtRecordEvent(start, stream);
        for (int i = 0; i < loops; i++)
            layernorm_kernel<<<blockNum, nullptr, stream>>>((GM_ADDR)inputDevice, (GM_ADDR)weightDevice, (GM_ADDR)biasDevice, (GM_ADDR)outputDevice, (GM_ADDR)tilingDevice);
        aclrtRecordEvent(stop, stream);
        aclrtSynchronizeStream(stream);
        float elapsed_ms = 0.0f;
        aclrtEventElapsedTime(&elapsed_ms, start, stop);
        latencies.push_back(elapsed_ms * 1000.0 / loops);
    }
    aclrtDestroyEvent(start); aclrtDestroyEvent(stop);

    std::sort(latencies.begin(), latencies.end());
    BenchResult res;
    res.latencies_us = latencies;
    res.min_us = latencies.front();
    res.median_us = latencies[latencies.size() / 2];
    res.p90_us = latencies[(size_t)(latencies.size() * 0.9)];
    double sum = 0;
    for (auto v : latencies) sum += v;
    res.mean_us = sum / latencies.size();
    double sq = 0;
    for (auto v : latencies) sq += (v - res.mean_us) * (v - res.mean_us);
    res.std_us = std::sqrt(sq / latencies.size());
    return res;
}

int run_batch(uint32_t batch, uint32_t blockDim,
    int32_t deviceId, int warmup, int loops, int repeat,
    const std::string &dataDir, const std::string &outputDir)
{
    uint32_t ld = 32;
    float eps = 1e-5f;
    uint32_t totalRows = batch * 256;

    const uint32_t MAX_ROWS_PER_BLOCK = 255;
    uint32_t blockNum = blockDim;
    if (blockNum > totalRows) blockNum = totalRows;
    if (blockNum == 0) blockNum = 1;
    uint32_t rowsPerBlock = (totalRows + blockNum - 1) / blockNum;
    while (rowsPerBlock > MAX_ROWS_PER_BLOCK) {
        blockNum++;
        rowsPerBlock = (totalRows + blockNum - 1) / blockNum;
    }

    LayerNormTilingData tiling;
    tiling.blockNum = blockNum;
    tiling.totalElements = (uint64_t)batch * 256 * 32;
    tiling.rowsPerBlock = rowsPerBlock;
    tiling.tailRows = totalRows - rowsPerBlock * (blockNum - 1);
    tiling.lastDimSize = ld;
    tiling.lastDimSizeF = (float)ld;
    tiling.eps = eps;

    size_t byteSize = (size_t)batch * 256 * 32 * sizeof(half);
    size_t wbSize = (size_t)32 * sizeof(half);

    uint8_t *tilingDevice = nullptr;
    aclrtMalloc((void **)&tilingDevice, sizeof(LayerNormTilingData), ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMemcpy(tilingDevice, sizeof(LayerNormTilingData), &tiling, sizeof(LayerNormTilingData), ACL_MEMCPY_HOST_TO_DEVICE);

    void *inputDevice = nullptr, *weightDevice = nullptr, *biasDevice = nullptr, *outputDevice = nullptr;
    aclrtMalloc(&inputDevice, byteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc(&weightDevice, wbSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc(&biasDevice, wbSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc(&outputDevice, byteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    std::string inputPath = dataDir + "/input_b" + std::to_string(batch) + "_fp16.bin";
    std::string weightPath = dataDir + "/weight_fp16.bin";
    std::string biasPath = dataDir + "/bias_fp16.bin";
    std::string outputPath = outputDir + "/output_b" + std::to_string(batch) + ".bin";

    uint8_t *hostBuf = new uint8_t[byteSize];
    ReadFile(inputPath, byteSize, hostBuf, byteSize);
    aclrtMemcpy(inputDevice, byteSize, hostBuf, byteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    delete[] hostBuf;

    uint8_t *wbBuf = new uint8_t[wbSize];
    ReadFile(weightPath, wbSize, wbBuf, wbSize);
    aclrtMemcpy(weightDevice, wbSize, wbBuf, wbSize, ACL_MEMCPY_HOST_TO_DEVICE);
    ReadFile(biasPath, wbSize, wbBuf, wbSize);
    aclrtMemcpy(biasDevice, wbSize, wbBuf, wbSize, ACL_MEMCPY_HOST_TO_DEVICE);
    delete[] wbBuf;

    aclrtStream stream;
    aclrtCreateStream(&stream);

    BenchResult res = measure_kernel_only(blockNum, stream,
        inputDevice, weightDevice, biasDevice, outputDevice, tilingDevice,
        warmup, loops, repeat);

    hostBuf = new uint8_t[byteSize];
    aclrtMemcpy(hostBuf, byteSize, outputDevice, byteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile(outputPath, hostBuf, byteSize);
    delete[] hostBuf;

    aclrtDestroyStream(stream);
    aclrtFree(inputDevice); aclrtFree(weightDevice);
    aclrtFree(biasDevice); aclrtFree(outputDevice); aclrtFree(tilingDevice);

    double inputBytes = (double)byteSize;
    double totalBytes = inputBytes * 2;
    double bw = totalBytes / res.median_us / 1e3;

    printf("RESULT batch=%u blockDim=%u median_us=%.1f mean_us=%.1f min_us=%.1f p90_us=%.1f std_us=%.2f bw=%.3f\n",
        batch, blockNum, res.median_us, res.mean_us, res.min_us, res.p90_us, res.std_us, bw);
    printf("RAW_LATENCIES:");
    for (size_t i = 0; i < res.latencies_us.size(); i++) {
        if (i > 0) printf(",");
        printf("%.1f", res.latencies_us[i]);
    }
    printf("\n");
    return 0;
}

int32_t main(int32_t argc, char *argv[])
{
    aclInit(nullptr);
    int32_t deviceId = 0;
    if (argc > 1) deviceId = std::atoi(argv[1]);

    auto ret = aclrtSetDevice(deviceId);
    if (ret != ACL_SUCCESS) { printf("aclrtSetDevice failed ret=%d\n", ret); aclFinalize(); return ret; }

    uint32_t batch = 1;
    uint32_t blockDim = 20;
    int warmup = 200;
    int loops = 100;
    int repeat = 5;
    std::string dataDir = "operators/layernorm/data";
    std::string outputDir = "operators/layernorm/ascendc/build/output";

    if (argc > 2) batch = std::atoi(argv[2]);
    if (argc > 3) blockDim = std::atoi(argv[3]);
    if (argc > 4) warmup = std::atoi(argv[4]);
    if (argc > 5) loops = std::atoi(argv[5]);
    if (argc > 6) repeat = std::atoi(argv[6]);
    if (argc > 7) dataDir = argv[7];
    if (argc > 8) outputDir = argv[8];

    run_batch(batch, blockDim, deviceId, warmup, loops, repeat, dataDir, outputDir);

    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}
