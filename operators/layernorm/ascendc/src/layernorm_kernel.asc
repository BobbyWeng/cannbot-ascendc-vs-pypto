#include "kernel_operator.h"
#include "layernorm_tiling.h"

class KernelLayerNorm {
public:
    __aicore__ inline KernelLayerNorm(AscendC::TPipe* pipe) { pipe_ = pipe; }

    __aicore__ inline void Init(GM_ADDR x, GM_ADDR w, GM_ADDR b, GM_ADDR y,
                                const __gm__ LayerNormTilingData* tiling)
    {
        this->tiling = tiling;
        uint32_t blockIdx = AscendC::GetBlockIdx();
        if (blockIdx >= tiling->blockNum) { enabled = false; return; }
        enabled = true;
        xAddr = (__gm__ half*)x; wAddr = (__gm__ half*)w; bAddr = (__gm__ half*)b; yAddr = (__gm__ half*)y;

        uint32_t ld = tiling->lastDimSize;
        uint32_t ldBytes = ld * sizeof(half);
        baseRow = blockIdx * tiling->rowsPerBlock;
        rows = (blockIdx == tiling->blockNum - 1) ? tiling->tailRows : tiling->rowsPerBlock;

        pipe_->InitBuffer(inBuf, 2, ldBytes);
        pipe_->InitBuffer(outBuf, 2, ldBytes);
        pipe_->InitBuffer(xFloatBuf, ld * sizeof(float));
        pipe_->InitBuffer(yFloatBuf, ld * sizeof(float));
        pipe_->InitBuffer(sclBuf, 1 * sizeof(float));
        pipe_->InitBuffer(rdBuf, ld * sizeof(float));
    }

    __aicore__ inline void Process()
    {
        if (!enabled || rows == 0) return;

        uint32_t ld = tiling->lastDimSize;
        float invLd = 1.0f / tiling->lastDimSizeF;
        int32_t dim = static_cast<int32_t>(ld);

        for (uint32_t i = 0; i < rows; i++) {
            uint32_t rowIdx = baseRow + i;

            AscendC::LocalTensor<half> xLocal = inBuf.AllocTensor<half>();
            xGm.SetGlobalBuffer(xAddr + rowIdx * ld, ld);
            AscendC::DataCopyPad(xLocal, xGm,
                {1, static_cast<uint16_t>(ld * sizeof(half)), 0, 0}, {false, 0, 0, 0});
            inBuf.EnQue(xLocal);

            xLocal = inBuf.DeQue<half>();
            AscendC::LocalTensor<float> xFloat = xFloatBuf.Get<float>();
            AscendC::LocalTensor<float> yFloat = yFloatBuf.Get<float>();
            AscendC::LocalTensor<float> scl = sclBuf.Get<float>();
            AscendC::LocalTensor<float> rd = rdBuf.Get<float>();

            AscendC::Cast(xFloat, xLocal, AscendC::RoundMode::CAST_NONE, dim);
            inBuf.FreeTensor(xLocal);

            AscendC::ReduceSum<float, true>(scl, xFloat, rd, dim);
            float meanVal = scl.GetValue(0) * invLd;

            AscendC::Adds(yFloat, xFloat, -meanVal, dim);

            AscendC::Mul(rd, yFloat, yFloat, dim);
            AscendC::ReduceSum<float, true>(scl, rd, rd, dim);
            float varVal = scl.GetValue(0) * invLd;

            AscendC::Duplicate<float>(rd, varVal + tiling->eps, ld);
            AscendC::Sqrt(rd, rd, ld);
            float rstd = 1.0f / rd.GetValue(0);

            AscendC::Duplicate<float>(rd, rstd, ld);
            AscendC::Mul(yFloat, yFloat, rd, ld);


            AscendC::LocalTensor<half> yLocal = outBuf.AllocTensor<half>();
            AscendC::Cast(yLocal, yFloat, AscendC::RoundMode::CAST_RINT, dim);

            yGm.SetGlobalBuffer(yAddr + rowIdx * ld, ld);
            AscendC::DataCopyPad(yGm, yLocal,
                {1, static_cast<uint16_t>(ld * sizeof(half)), 0, 0});
            outBuf.FreeTensor(yLocal);
        }
    }

private:
    AscendC::TPipe* pipe_;
    const __gm__ LayerNormTilingData* tiling;
    __gm__ half* xAddr; __gm__ half* yAddr;
    uint32_t baseRow; uint32_t rows; bool enabled;
    AscendC::GlobalTensor<half> xGm; AscendC::GlobalTensor<half> wGm;
    AscendC::GlobalTensor<half> bGm; AscendC::GlobalTensor<half> yGm;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inBuf;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outBuf;
    AscendC::TBuf<AscendC::TPosition::VECCALC> xFloatBuf;
    AscendC::TBuf<AscendC::TPosition::VECCALC> yFloatBuf;
    AscendC::TBuf<AscendC::TPosition::VECCALC> sclBuf;
    AscendC::TBuf<AscendC::TPosition::VECCALC> rdBuf;
};

extern "C" __global__ __vector__ void layernorm_kernel(GM_ADDR x, GM_ADDR w, GM_ADDR b, GM_ADDR y, GM_ADDR tiling)
{
    AscendC::TPipe pipe;
    KernelLayerNorm op(&pipe);
    op.Init(x, w, b, y, (__gm__ LayerNormTilingData*)tiling);
    op.Process();
}
