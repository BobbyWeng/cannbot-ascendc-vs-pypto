#include "kernel_operator.h"
#include "layernorm_tiling.h"

class KernelLayerNorm {
public:
    __aicore__ inline KernelLayerNorm(AscendC::TPipe* pipe)
    {
        pipe_ = pipe;
    }

    __aicore__ inline void Init(GM_ADDR x, GM_ADDR w, GM_ADDR b, GM_ADDR y,
                                const __gm__ LayerNormTilingData* tiling)
    {
        this->tiling = tiling;
        uint32_t blockIdx = AscendC::GetBlockIdx();
        if (blockIdx >= tiling->blockNum) {
            total = 0;
            tileNum = 0;
            tailTileElementNum = 0;
            return;
        }
        if (blockIdx < tiling->blockNum - 1) {
            total = tiling->numPerCore;
            tileNum = total / TILE_LENGTH;
            tailTileElementNum = TILE_LENGTH;
        } else {
            total = tiling->tailNumLastCore;
            tileNum = (total + TILE_LENGTH - 1) / TILE_LENGTH;
            tailTileElementNum = total - TILE_LENGTH * (tileNum - 1);
        }

        xAddr = (__gm__ half*)x;
        wAddr = (__gm__ half*)w;
        bAddr = (__gm__ half*)b;
        yAddr = (__gm__ half*)y;
        blockOffset = blockIdx * tiling->numPerCore;

        pipe_->InitBuffer(inQueueX, DOUBLE_BUFFER, TILE_LENGTH * sizeof(half));
        pipe_->InitBuffer(outQueueY, DOUBLE_BUFFER, TILE_LENGTH * sizeof(half));

        uint32_t ld = tiling->lastDimSize;
        pipe_->InitBuffer(xFloatBuf, TILE_LENGTH * sizeof(float));
        pipe_->InitBuffer(yFloatBuf, TILE_LENGTH * sizeof(float));
        pipe_->InitBuffer(meanBuf, 1 * sizeof(float));
        pipe_->InitBuffer(sclBuf, ld * sizeof(float));
        pipe_->InitBuffer(rdBuf, ld * sizeof(float));
        pipe_->InitBuffer(wbBuf, ld * sizeof(half) * 2);
    }

    __aicore__ inline void Process()
    {
        if (total == 0) return;

        for (uint32_t i = 0; i < tileNum; i++) {
            uint32_t count = (i == tileNum - 1) ? tailTileElementNum : TILE_LENGTH;
            CopyIn(i, count);
            Compute(i, count);
            CopyOut(i, count);
        }
    }

    __aicore__ inline void CopyIn(uint32_t tileIdx, uint32_t count)
    {
        AscendC::LocalTensor<half> xLocal = inQueueX.AllocTensor<half>();
        xGm.SetGlobalBuffer(xAddr + blockOffset + tileIdx * TILE_LENGTH, count);
        AscendC::DataCopyPad(xLocal, xGm,
            {1, static_cast<uint16_t>(count * sizeof(half)), 0, 0},
            {false, 0, 0, 0});
        inQueueX.EnQue(xLocal);
    }

    __aicore__ inline void Compute(uint32_t tileIdx, uint32_t count)
    {
        AscendC::LocalTensor<half> xLocal = inQueueX.DeQue<half>();
        AscendC::LocalTensor<float> xFloat = xFloatBuf.Get<float>();
        AscendC::LocalTensor<float> yFloat = yFloatBuf.Get<float>();
        AscendC::LocalTensor<float> meanT = meanBuf.Get<float>();
        AscendC::LocalTensor<float> scl = sclBuf.Get<float>();
        AscendC::LocalTensor<float> rd = rdBuf.Get<float>();
        AscendC::LocalTensor<half> wb = wbBuf.Get<half>();
        AscendC::LocalTensor<half> yLocal = outQueueY.AllocTensor<half>();

        AscendC::Cast(xFloat, xLocal, AscendC::RoundMode::CAST_NONE, count);

        uint32_t ld = tiling->lastDimSize;
        uint32_t rows = count / ld;
        float invLd = 1.0f / tiling->lastDimSizeF;
        float epsVal = tiling->eps;
        int32_t dim = static_cast<int32_t>(ld);

        wGm.SetGlobalBuffer(wAddr, ld);
        AscendC::DataCopy(wb, wGm, ld);
        bGm.SetGlobalBuffer(bAddr, ld);
        AscendC::DataCopy(wb[ld], bGm, ld);
        for (uint32_t r = 0; r < rows; r++) {
            uint32_t off = r * ld;

            AscendC::ReduceSum<float, true>(meanT, xFloat[off], yFloat[off], dim);
            float meanVal = meanT.GetValue(0) * invLd;

            AscendC::Adds(yFloat[off], xFloat[off], -meanVal, dim);

            AscendC::Mul(scl, yFloat[off], yFloat[off], dim);
            AscendC::ReduceSum<float, true>(meanT, scl, yFloat[off], dim);
            float varVal = meanT.GetValue(0) * invLd;

            AscendC::Duplicate<float>(scl, varVal + epsVal, ld);
            AscendC::Sqrt(scl, scl, ld);
            float rstd = 1.0f / scl.GetValue(0);

            AscendC::Duplicate<float>(scl, rstd, ld);
            AscendC::Mul(yFloat[off], yFloat[off], scl, ld);

        }

        AscendC::Cast(yLocal, yFloat, AscendC::RoundMode::CAST_RINT, count);
        outQueueY.EnQue<half>(yLocal);
        inQueueX.FreeTensor(xLocal);
    }

    __aicore__ inline void CopyOut(uint32_t tileIdx, uint32_t count)
    {
        AscendC::LocalTensor<half> yLocal = outQueueY.DeQue<half>();
        yGm.SetGlobalBuffer(yAddr + blockOffset + tileIdx * TILE_LENGTH, count);
        AscendC::DataCopyPad(yGm, yLocal,
            {1, static_cast<uint16_t>(count * sizeof(half)), 0, 0});
        outQueueY.FreeTensor(yLocal);
    }

private:
    AscendC::TPipe* pipe_;
    const __gm__ LayerNormTilingData* tiling;
    __gm__ half* xAddr;
    __gm__ half* wAddr;
    __gm__ half* bAddr;
    __gm__ half* yAddr;
    uint32_t blockOffset;
    AscendC::GlobalTensor<half> xGm;
    AscendC::GlobalTensor<half> wGm;
    AscendC::GlobalTensor<half> bGm;
    AscendC::GlobalTensor<half> yGm;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueX;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueY;
    AscendC::TBuf<AscendC::TPosition::VECCALC> xFloatBuf;
    AscendC::TBuf<AscendC::TPosition::VECCALC> yFloatBuf;
    AscendC::TBuf<AscendC::TPosition::VECCALC> meanBuf;
    AscendC::TBuf<AscendC::TPosition::VECCALC> sclBuf;
    AscendC::TBuf<AscendC::TPosition::VECCALC> rdBuf;
    AscendC::TBuf<AscendC::TPosition::VECCALC> wbBuf;
    uint32_t total;
    uint32_t tileNum;
    uint32_t tailTileElementNum;
};

extern "C" __global__ __vector__ void layernorm_kernel(GM_ADDR x, GM_ADDR w, GM_ADDR b, GM_ADDR y, GM_ADDR tiling)
{
    AscendC::TPipe pipe;
    KernelLayerNorm op(&pipe);
    op.Init(x, w, b, y, (__gm__ LayerNormTilingData*)tiling);
    op.Process();
}
