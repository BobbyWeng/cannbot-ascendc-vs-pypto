#include "kernel_operator.h"
#include "or_tiling.h"

class KernelOr {
public:
    __aicore__ inline KernelOr(AscendC::TPipe* pipe)
    {
        pipe_ = pipe;
    }

    __aicore__ inline void Init(GM_ADDR x1, GM_ADDR x2, GM_ADDR y,
                                const __gm__ OrTilingData* tiling)
    {
        this->tiling = tiling;
        uint32_t blockIdx = AscendC::GetBlockIdx();
        if (blockIdx >= tiling->blockNum) {
            total = 0;
            tileNum = 0;
            tailTileElementNum = 0;
            return;
        }
        if (blockIdx < tiling->blockNum - 1) {
            total = tiling->numPerCore;
            tileNum = total / TILE_LENGTH;
            tailTileElementNum = TILE_LENGTH;
        } else {
            total = tiling->tailNumLastCore;
            tileNum = (total + TILE_LENGTH - 1) / TILE_LENGTH;
            tailTileElementNum = total - TILE_LENGTH * (tileNum - 1);
        }

        x1Addr = (__gm__ uint8_t*)x1;
        x2Addr = (__gm__ uint8_t*)x2;
        yAddr = (__gm__ uint8_t*)y;
        blockOffset = blockIdx * tiling->numPerCore;

        pipe_->InitBuffer(inQueueX1, DOUBLE_BUFFER, TILE_LENGTH * sizeof(uint8_t));
        pipe_->InitBuffer(inQueueX2, DOUBLE_BUFFER, TILE_LENGTH * sizeof(uint8_t));
        pipe_->InitBuffer(outQueueY, DOUBLE_BUFFER, TILE_LENGTH * sizeof(uint8_t));
        pipe_->InitBuffer(tmpBuf, TILE_LENGTH * sizeof(half) * 3);
    }

    __aicore__ inline void Process()
    {
        if (total == 0) return;
        for (uint32_t i = 0; i < tileNum; i++) {
            uint32_t count = (i == tileNum - 1) ? tailTileElementNum : TILE_LENGTH;
            CopyIn(i, count);
            Compute(count);
            CopyOut(i, count);
        }
    }

    __aicore__ inline void CopyIn(uint32_t tileIdx, uint32_t count)
    {
        AscendC::LocalTensor<uint8_t> x1Local = inQueueX1.AllocTensor<uint8_t>();
        x1Gm.SetGlobalBuffer(x1Addr + blockOffset + tileIdx * TILE_LENGTH, count);
        AscendC::DataCopyPad(x1Local, x1Gm,
            {1, static_cast<uint16_t>(count * sizeof(uint8_t)), 0, 0},
            {false, 0, 0, 0});
        inQueueX1.EnQue(x1Local);

        AscendC::LocalTensor<uint8_t> x2Local = inQueueX2.AllocTensor<uint8_t>();
        x2Gm.SetGlobalBuffer(x2Addr + blockOffset + tileIdx * TILE_LENGTH, count);
        AscendC::DataCopyPad(x2Local, x2Gm,
            {1, static_cast<uint16_t>(count * sizeof(uint8_t)), 0, 0},
            {false, 0, 0, 0});
        inQueueX2.EnQue(x2Local);
    }

    __aicore__ inline void Compute(uint32_t count)
    {
        AscendC::LocalTensor<uint8_t> x1Local = inQueueX1.DeQue<uint8_t>();
        AscendC::LocalTensor<uint8_t> x2Local = inQueueX2.DeQue<uint8_t>();

        AscendC::LocalTensor<half> x1Half = tmpBuf.Get<half>(0);
        AscendC::LocalTensor<half> x2Half = x1Half[TILE_LENGTH];
        AscendC::LocalTensor<half> yHalf = x2Half[TILE_LENGTH];
        AscendC::LocalTensor<uint8_t> yLocal = outQueueY.AllocTensor<uint8_t>();

        AscendC::Cast(x1Half, x1Local, AscendC::RoundMode::CAST_NONE, count);
        AscendC::Cast(x2Half, x2Local, AscendC::RoundMode::CAST_NONE, count);
        AscendC::Max(yHalf, x1Half, x2Half, count);
        AscendC::Cast(yLocal, yHalf, AscendC::RoundMode::CAST_NONE, count);

        outQueueY.EnQue<uint8_t>(yLocal);
        inQueueX1.FreeTensor(x1Local);
        inQueueX2.FreeTensor(x2Local);
    }

    __aicore__ inline void CopyOut(uint32_t tileIdx, uint32_t count)
    {
        AscendC::LocalTensor<uint8_t> yLocal = outQueueY.DeQue<uint8_t>();
        yGm.SetGlobalBuffer(yAddr + blockOffset + tileIdx * TILE_LENGTH, count);
        AscendC::DataCopyPad(yGm, yLocal,
            {1, static_cast<uint16_t>(count * sizeof(uint8_t)), 0, 0});
        outQueueY.FreeTensor(yLocal);
    }

private:
    AscendC::TPipe* pipe_;
    const __gm__ OrTilingData* tiling;
    __gm__ uint8_t* x1Addr;
    __gm__ uint8_t* x2Addr;
    __gm__ uint8_t* yAddr;
    uint32_t blockOffset;
    AscendC::GlobalTensor<uint8_t> x1Gm;
    AscendC::GlobalTensor<uint8_t> x2Gm;
    AscendC::GlobalTensor<uint8_t> yGm;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueX1;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueX2;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueY;
    AscendC::TBuf<AscendC::TPosition::VECCALC> tmpBuf;
    uint32_t total;
    uint32_t tileNum;
    uint32_t tailTileElementNum;
};

extern "C" __global__ __vector__ void or_kernel(GM_ADDR x1, GM_ADDR x2, GM_ADDR y, GM_ADDR tiling)
{
    AscendC::TPipe pipe;
    KernelOr op(&pipe);
    op.Init(x1, x2, y, (__gm__ OrTilingData*)tiling);
    op.Process();
}
