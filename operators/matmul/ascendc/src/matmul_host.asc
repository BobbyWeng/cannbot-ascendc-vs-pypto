#include <cstdint>
#include <iostream>
#include <vector>
#include <string>
#include <chrono>
#include <algorithm>
#include <cmath>
#include <cstring>
#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_tiling/kernel_tiling.h"
#include "tiling/platform/platform_ascendc.h"
#include "tiling/tiling_api.h"

#define ASCENDC_CUBE_ONLY
#include "lib/matmul_intf.h"
#include "matmul_kernel.asc"

constexpr uint32_t HEADS = 12;
constexpr uint32_t M = 256;
constexpr uint32_t N = 32;
constexpr uint32_t K = 256;

struct BenchResult {
    double median_us;
    double mean_us;
    double min_us;
    double p90_us;
    double std_us;
    double cv;
    std::vector<double> latencies_us;
};

int32_t main(int32_t argc, char *argv[])
{
    aclInit(nullptr);
    int32_t deviceId = 0;
    if (argc > 1) deviceId = std::atoi(argv[1]);

    auto ret = aclrtSetDevice(deviceId);
    if (ret != ACL_SUCCESS) {
        printf("aclrtSetDevice(%d) failed, ret=%d\n", deviceId, ret);
        aclFinalize();
        return ret;
    }

    uint32_t batch = 1;
    int warmup = 200;
    int loops = 100;
    int repeat = 5;
    std::string dataDir = "operators/matmul/data";
    std::string outputDir = "operators/matmul/ascendc/build/output";

    if (argc > 2) batch = std::atoi(argv[2]);
    if (argc > 3) warmup = std::atoi(argv[3]);
    if (argc > 4) loops = std::atoi(argv[4]);
    if (argc > 5) repeat = std::atoi(argv[5]);
    if (argc > 6) dataDir = argv[6];
    if (argc > 7) outputDir = argv[7];

    uint32_t totalMatrices = batch * HEADS;
    uint64_t aElements = (uint64_t)totalMatrices * M * K;
    uint64_t bElements = (uint64_t)totalMatrices * K * N;
    uint64_t cElements = (uint64_t)totalMatrices * M * N;
    size_t aBytes = aElements * sizeof(half);
    size_t bBytes = bElements * sizeof(half);
    size_t cBytes = cElements * sizeof(float);

    auto ascendcPlatform = platform_ascendc::PlatformAscendCManager::GetInstance();
    int64_t coreNum = ascendcPlatform->GetCoreNumAic();

    // Use totalMatrices as blockDim (up to coreNum), each core handles one matrix
    uint32_t blockDim = (totalMatrices < (uint32_t)coreNum) ? totalMatrices : (uint32_t)coreNum;

    // Generate single-matrix tiling (SetDim=1, each core processes full matrices)
    optiling::TCubeTiling tilingData;
    matmul_tiling::MultiCoreMatmulTiling tilingApi(*ascendcPlatform);

    tilingApi.SetDim(1);

    tilingApi.SetAType(
        matmul_tiling::TPosition::GM, matmul_tiling::CubeFormat::ND,
        matmul_tiling::DataType::DT_FLOAT16, false);
    tilingApi.SetBType(
        matmul_tiling::TPosition::GM, matmul_tiling::CubeFormat::ND,
        matmul_tiling::DataType::DT_FLOAT16, false);
    tilingApi.SetCType(
        matmul_tiling::TPosition::GM, matmul_tiling::CubeFormat::ND,
        matmul_tiling::DataType::DT_FLOAT);
    tilingApi.SetBiasType(
        matmul_tiling::TPosition::GM, matmul_tiling::CubeFormat::ND,
        matmul_tiling::DataType::DT_FLOAT);

    tilingApi.SetOrgShape(M, N, K);
    tilingApi.SetShape(M, N, K);
    tilingApi.SetBufferSpace(-1, -1, -1);

    int64_t tilingRes = tilingApi.GetTiling(tilingData);
    if (tilingRes == -1) {
        printf("Generate tiling failed\n");
        aclrtResetDevice(deviceId);
        aclFinalize();
        return -1;
    }

    printf("TILING: coreNum=%ld blockDim=%u totalMatrices=%u\n",
        coreNum, blockDim, totalMatrices);

    uint32_t tilingSize = tilingData.GetDataSize();
    uint8_t tilingBuf[sizeof(TCubeTiling)];
    tilingData.SaveToBuffer(tilingBuf, tilingSize);

    size_t sysWorkspaceSize = (size_t)ascendcPlatform->GetLibApiWorkSpaceSize();
    size_t workspaceSize = sysWorkspaceSize;

    // Allocate device memory
    uint8_t *aDevice = nullptr;
    uint8_t *bDevice = nullptr;
    uint8_t *cDevice = nullptr;
    uint8_t *workspaceDevice = nullptr;
    uint8_t *tilingDevice = nullptr;

    aclrtMalloc((void**)&aDevice, aBytes, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&bDevice, bBytes, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&cDevice, cBytes, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&workspaceDevice, workspaceSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&tilingDevice, tilingSize, ACL_MEM_MALLOC_HUGE_FIRST);

    // Load data
    std::string aPath = dataDir + "/A_b" + std::to_string(batch) + "_perf_fp16.bin";
    std::string bPath = dataDir + "/B_b" + std::to_string(batch) + "_perf_fp16.bin";

    uint8_t *hostBuf = new uint8_t[aBytes];
    ReadFile(aPath, aBytes, hostBuf, aBytes);
    aclrtMemcpy(aDevice, aBytes, hostBuf, aBytes, ACL_MEMCPY_HOST_TO_DEVICE);
    delete[] hostBuf;

    hostBuf = new uint8_t[bBytes];
    ReadFile(bPath, bBytes, hostBuf, bBytes);
    aclrtMemcpy(bDevice, bBytes, hostBuf, bBytes, ACL_MEMCPY_HOST_TO_DEVICE);
    delete[] hostBuf;

    aclrtMemcpy(tilingDevice, tilingSize, tilingBuf, tilingSize, ACL_MEMCPY_HOST_TO_DEVICE);

    aclrtStream stream;
    aclrtCreateStream(&stream);

    // Warmup
    for (int i = 0; i < warmup; i++) {
        matmul_kernel<<<blockDim, 0, stream>>>(
            (__gm__ uint8_t*)aDevice, (__gm__ uint8_t*)bDevice,
            (__gm__ uint8_t*)cDevice, (__gm__ uint8_t*)workspaceDevice,
            (__gm__ uint8_t*)tilingDevice,
            totalMatrices, 0, 0);
    }
    aclrtSynchronizeStream(stream);

    aclrtEvent start, stop;
    aclrtCreateEvent(&start);
    aclrtCreateEvent(&stop);

    std::vector<double> latencies;
    latencies.reserve(repeat);

    for (int r = 0; r < repeat; r++) {
        aclrtRecordEvent(start, stream);
        for (int i = 0; i < loops; i++) {
            matmul_kernel<<<blockDim, 0, stream>>>(
                (__gm__ uint8_t*)aDevice, (__gm__ uint8_t*)bDevice,
                (__gm__ uint8_t*)cDevice, (__gm__ uint8_t*)workspaceDevice,
                (__gm__ uint8_t*)tilingDevice,
                totalMatrices, 0, 0);
        }
        aclrtRecordEvent(stop, stream);
        aclrtSynchronizeStream(stream);

        float elapsed_ms = 0.0f;
        aclrtEventElapsedTime(&elapsed_ms, start, stop);
        double elapsed_us = elapsed_ms * 1000.0 / loops;
        latencies.push_back(elapsed_us);
    }

    aclrtDestroyEvent(start);
    aclrtDestroyEvent(stop);

    std::sort(latencies.begin(), latencies.end());
    BenchResult res;
    res.latencies_us = latencies;
    res.min_us = latencies.front();
    res.median_us = latencies[latencies.size() / 2];
    res.p90_us = latencies[(size_t)(latencies.size() * 0.9)];
    double sum = 0;
    for (auto v : latencies) sum += v;
    res.mean_us = sum / latencies.size();
    double sq_sum = 0;
    for (auto v : latencies) sq_sum += (v - res.mean_us) * (v - res.mean_us);
    res.std_us = std::sqrt(sq_sum / latencies.size());
    res.cv = res.std_us / res.mean_us * 100.0;

    // Read output back
    hostBuf = new uint8_t[cBytes];
    aclrtMemcpy(hostBuf, cBytes, cDevice, cBytes, ACL_MEMCPY_DEVICE_TO_HOST);

    // Convert float -> half for storage
    float* fOut = reinterpret_cast<float*>(hostBuf);
    half* hOut = new half[cElements];
    for (uint64_t i = 0; i < cElements; i++) {
        hOut[i] = (half)fOut[i];
    }
    std::string outputPath = outputDir + "/output_b" + std::to_string(batch) + "_perf_fp16.bin";
    WriteFile(outputPath, hOut, cElements * sizeof(half));
    delete[] hOut;
    delete[] hostBuf;

    aclrtDestroyStream(stream);

    aclrtFree(aDevice);
    aclrtFree(bDevice);
    aclrtFree(cDevice);
    aclrtFree(workspaceDevice);
    aclrtFree(tilingDevice);

    uint32_t matricesPerCore = (totalMatrices + blockDim - 1) / blockDim;
    uint32_t tailMatrices = totalMatrices - (blockDim - 1) * matricesPerCore;
    double totalFlops = 2.0 * (double)totalMatrices * M * N * K;
    double tflops = totalFlops / res.median_us / 1e6;

    printf("RESULT batch=%u blockDim=%u matricesPerCore=%u tailMatrices=%u totalMatrices=%u "
           "coreNum=%ld "
           "median_us=%.1f mean_us=%.1f min_us=%.1f p90_us=%.1f std_us=%.2f cv=%.2f "
           "tflops=%.4f\n",
        batch, blockDim, matricesPerCore, tailMatrices, totalMatrices,
        coreNum,
        res.median_us, res.mean_us, res.min_us, res.p90_us, res.std_us, res.cv,
        tflops);
    printf("RAW_LATENCIES:");
    for (size_t i = 0; i < res.latencies_us.size(); i++) {
        if (i > 0) printf(",");
        printf("%.1f", res.latencies_us[i]);
    }
    printf("\n");

    printf("FLOPS: total=%0.f per_matrix=%u median_us=%.1f TFLOPS=%.4f coreNum=%ld\n",
        totalFlops, 2 * M * N * K, res.median_us, tflops, coreNum);

    printf("KERNEL_MAP: 1 logical_call=%u compute_kernels=%u aux_kernels=0 "
           "kernels_per_call=1 blockDim=%u matricesPerCore=%u\n",
        totalMatrices, blockDim, blockDim, matricesPerCore);

    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}
