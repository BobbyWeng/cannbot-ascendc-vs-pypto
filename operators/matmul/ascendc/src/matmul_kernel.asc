#define ASCENDC_CUBE_ONLY
#include "kernel_operator.h"
#include "lib/matmul_intf.h"
#include "matmul_tiling.h"

using namespace AscendC;

template <typename AType, typename BType, typename CType, typename BiasType>
class KernelMatMul {
public:
    __aicore__ inline KernelMatMul() {}

    __aicore__ inline void Init(
        __gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ uint8_t* c,
        const TCubeTiling& tiling)
    {
        this->tiling = tiling;
        aBase = reinterpret_cast<__gm__ AType*>(a);
        bBase = reinterpret_cast<__gm__ BType*>(b);
        cBase = reinterpret_cast<__gm__ CType*>(c);
        aStride = M * K;
        bStride = K * N;
        cStride = M * N;
    }

    __aicore__ inline void ProcessOne(TPipe* pipe, uint32_t matIdx)
    {
        aGlobal.SetGlobalBuffer(aBase + matIdx * aStride, M * K);
        bGlobal.SetGlobalBuffer(bBase + matIdx * bStride, K * N);
        cGlobal.SetGlobalBuffer(cBase + matIdx * cStride, M * N);

        matmulObj.SetTensorA(aGlobal, false);
        matmulObj.SetTensorB(bGlobal, false);
        matmulObj.IterateAll(cGlobal);
        matmulObj.End();
    }

    AscendC::Matmul<
        AscendC::MatmulType<TPosition::GM, CubeFormat::ND, half>,
        AscendC::MatmulType<TPosition::GM, CubeFormat::ND, half>,
        AscendC::MatmulType<TPosition::GM, CubeFormat::ND, float>,
        AscendC::MatmulType<TPosition::GM, CubeFormat::ND, float>,
        CFG_NORM>
        matmulObj;

private:
    TCubeTiling tiling;
    GlobalTensor<half> aGlobal;
    GlobalTensor<half> bGlobal;
    GlobalTensor<float> cGlobal;
    __gm__ half* aBase;
    __gm__ half* bBase;
    __gm__ float* cBase;
    uint32_t aStride, bStride, cStride;
    static constexpr uint32_t M = 256;
    static constexpr uint32_t N = 32;
    static constexpr uint32_t K = 256;
};

extern "C" __global__ __cube__ void matmul_kernel(
    __gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ uint8_t* c,
    __gm__ uint8_t* workspace, __gm__ uint8_t* tilingGm,
    uint32_t matIdx, uint32_t ctx1, uint32_t ctx2)
{
    (void)ctx1; (void)ctx2;
    TCubeTiling tiling;
    auto tiling32 = reinterpret_cast<__gm__ uint32_t*>(tilingGm);
    auto ptr = reinterpret_cast<uint32_t*>(&tiling);
    for (uint32_t i = 0; i < sizeof(TCubeTiling) / sizeof(uint32_t); i++) {
        ptr[i] = tiling32[i];
    }

    TPipe pipe;
    KernelMatMul<half, half, float, float> kernel;
    kernel.Init(a, b, c, tiling);
    REGIST_MATMUL_OBJ(&pipe, GetSysWorkSpacePtr(), kernel.matmulObj, &tiling);
    kernel.ProcessOne(&pipe, matIdx);
}
