#include "kernel_operator.h"
#include "equal_tiling.h"

using namespace AscendC;

class KernelEqual {
public:
    __aicore__ inline KernelEqual(TPipe* pipe)
    {
        pipe_ = pipe;
    }

    __aicore__ inline void Init(GM_ADDR x1, GM_ADDR x2, GM_ADDR y,
                                const __gm__ EqualTilingData* tiling)
    {
        this->tiling = tiling;
        uint32_t blockIdx = GetBlockIdx();
        if (blockIdx >= tiling->blockNum) {
            total = 0;
            tileNum = 0;
            tailTileElementNum = 0;
            return;
        }
        if (blockIdx < tiling->blockNum - 1) {
            total = tiling->numPerCore;
            tileNum = total / TILE_LENGTH;
            tailTileElementNum = TILE_LENGTH;
        } else {
            total = tiling->tailNumLastCore;
            tileNum = (total + TILE_LENGTH - 1) / TILE_LENGTH;
            tailTileElementNum = total - TILE_LENGTH * (tileNum - 1);
        }

        x1Addr = (__gm__ half*)x1;
        x2Addr = (__gm__ half*)x2;
        yAddr = (__gm__ uint8_t*)y;
        blockOffset = blockIdx * tiling->numPerCore;

        pipe_->InitBuffer(inQueueX1, DOUBLE_BUFFER, TILE_LENGTH * sizeof(half));
        pipe_->InitBuffer(inQueueX2, DOUBLE_BUFFER, TILE_LENGTH * sizeof(half));
        pipe_->InitBuffer(outQueueY, DOUBLE_BUFFER, TILE_LENGTH * sizeof(uint8_t));
    }

    __aicore__ inline void Process()
    {
        if (total == 0) return;
        for (uint32_t i = 0; i < tileNum; i++) {
            uint32_t count = (i == tileNum - 1) ? tailTileElementNum : TILE_LENGTH;
            CopyIn(i, count);
            Compute(count);
            CopyOut(i, count);
        }
    }

    __aicore__ inline void CopyIn(uint32_t tileIdx, uint32_t count)
    {
        LocalTensor<half> x1Local = inQueueX1.AllocTensor<half>();
        x1Gm.SetGlobalBuffer(x1Addr + blockOffset + tileIdx * TILE_LENGTH, count);
        DataCopyPad(x1Local, x1Gm,
            {1, static_cast<uint16_t>(count * sizeof(half)), 0, 0},
            {false, 0, 0, 0});
        inQueueX1.EnQue(x1Local);

        LocalTensor<half> x2Local = inQueueX2.AllocTensor<half>();
        x2Gm.SetGlobalBuffer(x2Addr + blockOffset + tileIdx * TILE_LENGTH, count);
        DataCopyPad(x2Local, x2Gm,
            {1, static_cast<uint16_t>(count * sizeof(half)), 0, 0},
            {false, 0, 0, 0});
        inQueueX2.EnQue(x2Local);
    }

    __aicore__ inline void Compute(uint32_t count)
    {
        LocalTensor<half> x1Local = inQueueX1.DeQue<half>();
        LocalTensor<half> x2Local = inQueueX2.DeQue<half>();
        LocalTensor<uint8_t> yLocal = outQueueY.AllocTensor<uint8_t>();

        // Use vectorized Sub/Abs + Compares to get packed mask
        // Then manually expand the mask using scalar operations
        // Process in 128-element chunks for Compare alignment
        
        // Step 1: Use Compare to get packed mask (requires aligned count)
        uint32_t alignedCount = (count / 128) * 128;
        
        // For aligned portion: use vectorized Compare
        // Result goes directly into yLocal for the aligned part
        // (we'll read the Compare output as packed bits and expand)
        
        // Actually, the Compare output IS the packed uint8_t mask.
        // For 128 elements: 16 bytes of packed mask.
        // For 8192 elements: 1024 bytes.
        // The yLocal output is 8192 bytes.
        // We can write packed mask into first 1024 bytes of yLocal,
        // then expand to 8192 bytes.
        
        // But we don't have enough space in yLocal for both packed (1024) and expanded (8192).
        // Alternative: process one 128-element chunk at a time:
        // 1. Compare 128 elements -> 16 bytes packed mask
        // 2. Expand 16 bytes -> 128 bytes in yLocal
        // 3. Repeat for all chunks
        
        // Expansion algorithm for one chunk:
        // mask has 16 bytes (128 bits). For byte j, bits 0..7 map to elements j*8..j*8+7
        // For each byte j:
        //   For each bit k in 0..7:
        //     output[j*8+k] = (mask[j] >> k) & 1
        
        // The expansion can be done with scalar Get/SetValue operations
        // which are slow but necessary since Select doesn't work.
        
        // Alternative expansion: use Sub/Abs on the packed mask and 
        // compute each expanded byte using the packed byte's value!
        
        // For a packed byte with value V (0-255):
        // bit0 = V & 1 = V % 2
        // bit1 = (V >> 1) & 1 = (V//2) % 2
        // etc.
        
        // To compute V % 2 using Compare on float:
        // Cast V to float, compute V/2, check if frac(V/2) != 0
        // Too complex. Let me just use scalar.
        
        uint32_t CHUNK_ELEMS = 128;
        uint32_t numChunks = count / CHUNK_ELEMS;
        
        for (uint32_t ch = 0; ch < numChunks; ch++) {
            uint32_t elemOff = ch * CHUNK_ELEMS;
            
            LocalTensor<half> x1Chunk = x1Local[elemOff];
            LocalTensor<half> x2Chunk = x2Local[elemOff];
            LocalTensor<uint8_t> yChunk = yLocal[elemOff];
            
            // Compare: packed mask goes to yChunk (first 16 bytes are mask)
            LocalTensor<uint8_t> maskedChunk = yChunk;
            Compare(maskedChunk, x1Chunk, x2Chunk, CMPMODE::EQ, CHUNK_ELEMS);
            
            // Now expand packed bits in-place
            // Read from bottom of chunk (bytes 0-15), write to top
            // Process in reverse to avoid overwrite
            for (int32_t j = 15; j >= 0; j--) {
                uint8_t byteVal = maskedChunk.GetValue(j);
                for (uint32_t b = 0; b < 8; b++) {
                    uint32_t elemIdx = j * 8 + b;
                    yChunk[elemIdx].SetValue(0, (byteVal >> b) & 1);
                }
            }
        }

        outQueueY.EnQue<uint8_t>(yLocal);
        inQueueX1.FreeTensor(x1Local);
        inQueueX2.FreeTensor(x2Local);
    }

    __aicore__ inline void CopyOut(uint32_t tileIdx, uint32_t count)
    {
        LocalTensor<uint8_t> yLocal = outQueueY.DeQue<uint8_t>();
        yGm.SetGlobalBuffer(yAddr + blockOffset + tileIdx * TILE_LENGTH, count);
        DataCopyPad(yGm, yLocal,
            {1, static_cast<uint16_t>(count * sizeof(uint8_t)), 0, 0});
        outQueueY.FreeTensor(yLocal);
    }

private:
    TPipe* pipe_;
    const __gm__ EqualTilingData* tiling;
    __gm__ half* x1Addr;
    __gm__ half* x2Addr;
    __gm__ uint8_t* yAddr;
    uint32_t blockOffset;
    GlobalTensor<half> x1Gm;
    GlobalTensor<half> x2Gm;
    GlobalTensor<uint8_t> yGm;
    TQue<TPosition::VECIN, 1> inQueueX1;
    TQue<TPosition::VECIN, 1> inQueueX2;
    TQue<TPosition::VECOUT, 1> outQueueY;
    TBuf<TPosition::VECCALC> tmpBuf;
    uint32_t total;
    uint32_t tileNum;
    uint32_t tailTileElementNum;
};

extern "C" __global__ __vector__ void equal_kernel(GM_ADDR x1, GM_ADDR x2, GM_ADDR y, GM_ADDR tiling)
{
    TPipe pipe;
    KernelEqual op(&pipe);
    op.Init(x1, x2, y, (__gm__ EqualTilingData*)tiling);
    op.Process();
}
