#include "kernel_operator.h"
#include "add_tiling.h"

class KernelAdd {
public:
    __aicore__ inline KernelAdd(AscendC::TPipe* pipe)
    {
        pipe_ = pipe;
    }

    __aicore__ inline void Init(GM_ADDR x1, GM_ADDR x2, GM_ADDR x3, GM_ADDR x4, GM_ADDR y,
                                const __gm__ AddTilingData* tiling)
    {
        this->tiling = tiling;
        uint32_t blockIdx = AscendC::GetBlockIdx();
        if (blockIdx >= tiling->blockNum) {
            total = 0;
            tileNum = 0;
            tailTileElementNum = 0;
            return;
        }
        if (blockIdx < tiling->blockNum - 1) {
            total = tiling->numPerCore;
            tileNum = total / TILE_LENGTH;
            tailTileElementNum = TILE_LENGTH;
        } else {
            total = tiling->tailNumLastCore;
            tileNum = (total + TILE_LENGTH - 1) / TILE_LENGTH;
            tailTileElementNum = total - TILE_LENGTH * (tileNum - 1);
        }

        x1Addr = (__gm__ half*)x1;
        x2Addr = (__gm__ half*)x2;
        x3Addr = (__gm__ half*)x3;
        x4Addr = (__gm__ half*)x4;
        yAddr = (__gm__ half*)y;
        blockOffset = blockIdx * tiling->numPerCore;

        pipe_->InitBuffer(inQueueX1, DOUBLE_BUFFER, TILE_LENGTH * sizeof(half));
        pipe_->InitBuffer(inQueueX2, DOUBLE_BUFFER, TILE_LENGTH * sizeof(half));
        pipe_->InitBuffer(inQueueX3, DOUBLE_BUFFER, TILE_LENGTH * sizeof(half));
        pipe_->InitBuffer(inQueueX4, DOUBLE_BUFFER, TILE_LENGTH * sizeof(half));
        pipe_->InitBuffer(tmpBuf, TILE_LENGTH * sizeof(half));
        pipe_->InitBuffer(outQueueY, DOUBLE_BUFFER, TILE_LENGTH * sizeof(half));
    }

    __aicore__ inline void Process()
    {
        if (total == 0) return;
        for (uint32_t i = 0; i < tileNum; i++) {
            uint32_t count = (i == tileNum - 1) ? tailTileElementNum : TILE_LENGTH;
            CopyIn(i, count);
            Compute(count);
            CopyOut(i, count);
        }
    }

    __aicore__ inline void CopyIn(uint32_t tileIdx, uint32_t count)
    {
        AscendC::LocalTensor<half> x1Local = inQueueX1.AllocTensor<half>();
        x1Gm.SetGlobalBuffer(x1Addr + blockOffset + tileIdx * TILE_LENGTH, count);
        AscendC::DataCopyPad(x1Local, x1Gm,
            {1, static_cast<uint16_t>(count * sizeof(half)), 0, 0},
            {false, 0, 0, 0});
        inQueueX1.EnQue(x1Local);

        AscendC::LocalTensor<half> x2Local = inQueueX2.AllocTensor<half>();
        x2Gm.SetGlobalBuffer(x2Addr + blockOffset + tileIdx * TILE_LENGTH, count);
        AscendC::DataCopyPad(x2Local, x2Gm,
            {1, static_cast<uint16_t>(count * sizeof(half)), 0, 0},
            {false, 0, 0, 0});
        inQueueX2.EnQue(x2Local);

        AscendC::LocalTensor<half> x3Local = inQueueX3.AllocTensor<half>();
        x3Gm.SetGlobalBuffer(x3Addr + blockOffset + tileIdx * TILE_LENGTH, count);
        AscendC::DataCopyPad(x3Local, x3Gm,
            {1, static_cast<uint16_t>(count * sizeof(half)), 0, 0},
            {false, 0, 0, 0});
        inQueueX3.EnQue(x3Local);

        AscendC::LocalTensor<half> x4Local = inQueueX4.AllocTensor<half>();
        x4Gm.SetGlobalBuffer(x4Addr + blockOffset + tileIdx * TILE_LENGTH, count);
        AscendC::DataCopyPad(x4Local, x4Gm,
            {1, static_cast<uint16_t>(count * sizeof(half)), 0, 0},
            {false, 0, 0, 0});
        inQueueX4.EnQue(x4Local);
    }

    __aicore__ inline void Compute(uint32_t count)
    {
        AscendC::LocalTensor<half> x1Local = inQueueX1.DeQue<half>();
        AscendC::LocalTensor<half> x2Local = inQueueX2.DeQue<half>();
        AscendC::LocalTensor<half> x3Local = inQueueX3.DeQue<half>();
        AscendC::LocalTensor<half> x4Local = inQueueX4.DeQue<half>();

        AscendC::LocalTensor<half> tmpLocal = tmpBuf.AllocTensor<half>();
        AscendC::LocalTensor<half> yLocal = outQueueY.AllocTensor<half>();

        AscendC::Add(tmpLocal, x1Local, x2Local, count);
        AscendC::Add(tmpLocal, tmpLocal, x3Local, count);
        AscendC::Add(yLocal, tmpLocal, x4Local, count);

        outQueueY.EnQue<half>(yLocal);
        inQueueX1.FreeTensor(x1Local);
        inQueueX2.FreeTensor(x2Local);
        inQueueX3.FreeTensor(x3Local);
        inQueueX4.FreeTensor(x4Local);
        tmpBuf.FreeTensor(tmpLocal);
    }

    __aicore__ inline void CopyOut(uint32_t tileIdx, uint32_t count)
    {
        AscendC::LocalTensor<half> yLocal = outQueueY.DeQue<half>();
        yGm.SetGlobalBuffer(yAddr + blockOffset + tileIdx * TILE_LENGTH, count);
        AscendC::DataCopyPad(yGm, yLocal,
            {1, static_cast<uint16_t>(count * sizeof(half)), 0, 0});
        outQueueY.FreeTensor(yLocal);
    }

private:
    AscendC::TPipe* pipe_;
    const __gm__ AddTilingData* tiling;
    __gm__ half* x1Addr;
    __gm__ half* x2Addr;
    __gm__ half* x3Addr;
    __gm__ half* x4Addr;
    __gm__ half* yAddr;
    uint32_t blockOffset;
    AscendC::GlobalTensor<half> x1Gm;
    AscendC::GlobalTensor<half> x2Gm;
    AscendC::GlobalTensor<half> x3Gm;
    AscendC::GlobalTensor<half> x4Gm;
    AscendC::GlobalTensor<half> yGm;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueX1;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueX2;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueX3;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueX4;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueY;
    AscendC::TBuf<AscendC::TPosition::VECCALC> tmpBuf;
    uint32_t total;
    uint32_t tileNum;
    uint32_t tailTileElementNum;
};

extern "C" __global__ __vector__ void add_kernel(GM_ADDR x1, GM_ADDR x2, GM_ADDR x3, GM_ADDR x4, GM_ADDR y, GM_ADDR tiling)
{
    AscendC::TPipe pipe;
    KernelAdd op(&pipe);
    op.Init(x1, x2, x3, x4, y, (__gm__ AddTilingData*)tiling);
    op.Process();
}
