#include <cstdint>
#include <iostream>
#include <vector>
#include <string>
#include <chrono>
#include <algorithm>
#include <cmath>
#include <cstring>
#include "acl/acl.h"
#include "transpose_tiling.h"
#include "data_utils.h"
#include "transpose_kernel.asc"

struct BenchResult { double median_us, mean_us, min_us, p90_us, std_us; std::vector<double> latencies_us; };

BenchResult measure_kernel_only(uint32_t blockNum, aclrtStream stream,
    void *inputDevice, void *outputDevice, void *tilingDevice, int warmup, int loops, int repeat)
{
    for (int i = 0; i < warmup; i++) transpose_kernel<<<blockNum, nullptr, stream>>>((GM_ADDR)inputDevice, (GM_ADDR)outputDevice, (GM_ADDR)tilingDevice);
    aclrtSynchronizeStream(stream);
    aclrtEvent start, stop; aclrtCreateEvent(&start); aclrtCreateEvent(&stop);
    std::vector<double> latencies;
    for (int r = 0; r < repeat; r++) {
        aclrtRecordEvent(start, stream);
        for (int i = 0; i < loops; i++) transpose_kernel<<<blockNum, nullptr, stream>>>((GM_ADDR)inputDevice, (GM_ADDR)outputDevice, (GM_ADDR)tilingDevice);
        aclrtRecordEvent(stop, stream); aclrtSynchronizeStream(stream);
        float elapsed_ms = 0.0f; aclrtEventElapsedTime(&elapsed_ms, start, stop);
        latencies.push_back(elapsed_ms * 1000.0 / loops);
    }
    aclrtDestroyEvent(start); aclrtDestroyEvent(stop);
    std::sort(latencies.begin(), latencies.end());
    BenchResult res; res.latencies_us = latencies; res.min_us = latencies.front(); res.median_us = latencies[latencies.size() / 2];
    res.p90_us = latencies[(size_t)(latencies.size() * 0.9)];
    double sum = 0; for (auto v : latencies) sum += v; res.mean_us = sum / latencies.size();
    double sq = 0; for (auto v : latencies) sq += (v - res.mean_us) * (v - res.mean_us); res.std_us = std::sqrt(sq / latencies.size());
    return res;
}

int run_batch(uint32_t batch, uint32_t blockDim, uint32_t tileH, uint32_t tileW,
    int32_t deviceId, int warmup, int loops, int repeat,
    const std::string &dataDir, const std::string &outputDir)
{
    const uint32_t H = 256; const uint32_t W = 384;
    uint64_t inputElements = (uint64_t)batch * H * W;
    uint64_t outputElements = (uint64_t)batch * W * H;
    size_t inputByteSize = inputElements * sizeof(half);
    size_t outputByteSize = outputElements * sizeof(half);

    std::string inputPath = dataDir + "/input_b" + std::to_string(batch) + "_fp16.bin";
    std::string outputPath = outputDir + "/output_b" + std::to_string(batch) + ".bin";

    uint64_t globalTiles = (uint64_t)batch * ((H + tileH - 1) / tileH) * ((W + tileW - 1) / tileW);
    uint32_t blockNum = blockDim;
    if (blockNum > globalTiles) blockNum = (uint32_t)globalTiles;
    if (blockNum == 0) blockNum = 1;

    TransposeTilingData tiling;
    tiling.blockNum = blockNum;
    tiling.totalBatches = batch;
    tiling.H = H; tiling.W = W;
    tiling.tileH = tileH; tiling.tileW = tileW;

    uint8_t *tilingDevice = nullptr;
    aclrtMalloc((void**)&tilingDevice, sizeof(TransposeTilingData), ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMemcpy(tilingDevice, sizeof(TransposeTilingData), &tiling, sizeof(TransposeTilingData), ACL_MEMCPY_HOST_TO_DEVICE);

    void *inputDevice = nullptr; void *outputDevice = nullptr;
    aclrtMalloc(&inputDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc(&outputDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    uint8_t *hostBuf = new uint8_t[inputByteSize];
    ReadFile(inputPath, inputByteSize, hostBuf, inputByteSize);
    aclrtMemcpy(inputDevice, inputByteSize, hostBuf, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    delete[] hostBuf;

    aclrtStream stream; aclrtCreateStream(&stream);
    BenchResult res = measure_kernel_only(blockNum, stream, inputDevice, outputDevice, tilingDevice, warmup, loops, repeat);

    hostBuf = new uint8_t[outputByteSize];
    aclrtMemcpy(hostBuf, outputByteSize, outputDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile(outputPath, hostBuf, outputByteSize); delete[] hostBuf;
    aclrtDestroyStream(stream); aclrtFree(inputDevice); aclrtFree(outputDevice); aclrtFree(tilingDevice);

    printf("RESULT batch=%u blockNum=%u tileH=%u tileW=%u median_us=%.1f mean_us=%.1f min_us=%.1f p90_us=%.1f std_us=%.2f cv=%.2f\n",
        batch, blockNum, tileH, tileW, res.median_us, res.mean_us, res.min_us, res.p90_us, res.std_us, res.std_us / res.mean_us * 100.0);
    printf("RAW_LATENCIES:"); for (auto v : res.latencies_us) printf("%.1f,", v); printf("\n");
    return 0;
}

int32_t main(int32_t argc, char *argv[]) {
    aclInit(nullptr); int32_t deviceId = 0; if (argc > 1) deviceId = std::atoi(argv[1]);
    auto ret = aclrtSetDevice(deviceId); if (ret != ACL_SUCCESS) { printf("SetDevice failed=%d\n", ret); aclFinalize(); return ret; }
    uint32_t batch = 1; uint32_t blockDim = 20; uint32_t tileH = 32; uint32_t tileW = 32;
    int warmup = 100; int loops = 1000; int repeat = 10;
    std::string dataDir = "operators/transpose/data"; std::string outputDir = "operators/transpose/ascendc/build/output";
    if (argc > 2) batch = std::atoi(argv[2]); if (argc > 3) blockDim = std::atoi(argv[3]);
    if (argc > 4) tileH = std::atoi(argv[4]); if (argc > 5) tileW = std::atoi(argv[5]);
    if (argc > 6) warmup = std::atoi(argv[6]); if (argc > 7) loops = std::atoi(argv[7]); if (argc > 8) repeat = std::atoi(argv[8]);
    if (argc > 9) dataDir = argv[9]; if (argc > 10) outputDir = argv[10];
    run_batch(batch, blockDim, tileH, tileW, deviceId, warmup, loops, repeat, dataDir, outputDir);
    aclrtResetDevice(deviceId); aclFinalize(); return 0;
}
