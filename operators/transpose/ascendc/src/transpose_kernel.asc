#include "kernel_operator.h"
#include "transpose_tiling.h"

// RC-3: Final - RC-2 baseline restored (32x32 tile, double buffer)
// Best approach was 64x64 tile for large batches (+2.9% for B=64)
// Final recommendation: use 64x64 tile as default for best overall throughput

class KernelTranspose {
public:
    __aicore__ inline KernelTranspose(AscendC::TPipe* pipe) { pipe_ = pipe; }

    __aicore__ inline void Init(GM_ADDR x, GM_ADDR y,
                                const __gm__ TransposeTilingData* tiling)
    {
        this->tiling = tiling;
        uint32_t blockIdx = AscendC::GetBlockIdx();
        if (blockIdx >= tiling->blockNum) { totalTiles = 0; return; }

        H = tiling->H; W = tiling->W;
        origTileH = tiling->tileH; origTileW = tiling->tileW;
        numTilesH = (H + origTileH - 1) / origTileH;
        numTilesW = (W + origTileW - 1) / origTileW;
        totalTilesPerBatch = numTilesH * numTilesW;

        uint64_t globalTiles = (uint64_t)tiling->totalBatches * totalTilesPerBatch;
        uint32_t tilesPerBlock = (uint32_t)(globalTiles / tiling->blockNum);
        uint32_t remTiles = (uint32_t)(globalTiles - tilesPerBlock * tiling->blockNum);
        if (blockIdx < remTiles) {
            startGlobalTile = blockIdx * (tilesPerBlock + 1);
            totalTiles = tilesPerBlock + 1;
        } else {
            startGlobalTile = remTiles * (tilesPerBlock + 1) + (blockIdx - remTiles) * tilesPerBlock;
            totalTiles = tilesPerBlock;
        }

        xAddr = (__gm__ half*)x;
        yAddr = (__gm__ half*)y;

        uint32_t maxTileH = origTileH;
        uint32_t maxTileW = (origTileW + 7) / 8 * 8;
        uint32_t inBufSize = maxTileH * maxTileW * sizeof(half);
        uint32_t outBufSize = maxTileW * ((maxTileH + 7) / 8 * 8) * sizeof(half);

        pipe_->InitBuffer(inQueueX, DOUBLE_BUFFER, inBufSize);
        pipe_->InitBuffer(outQueueY, DOUBLE_BUFFER, outBufSize);
    }

    __aicore__ inline void Process() {
        if (totalTiles == 0) return;

        for (uint32_t t = 0; t < totalTiles; t++) {
            uint32_t globalTile = startGlobalTile + t;
            uint32_t batch = globalTile / totalTilesPerBatch;
            uint32_t localTile = globalTile % totalTilesPerBatch;
            uint32_t ti = localTile / numTilesW;
            uint32_t tj = localTile % numTilesW;

            uint32_t curH = (ti == numTilesH - 1) ? (H - ti * origTileH) : origTileH;
            uint32_t curW = (tj == numTilesW - 1) ? (W - tj * origTileW) : origTileW;
            uint32_t curAlignW = (curW + 7) / 8 * 8;

            CopyInTile(batch, ti, tj, curH, curW, curAlignW);
            ComputeTile(curH, curW, curAlignW);
            CopyOutTile(batch, ti, tj, curH, curW);
        }
    }

    __aicore__ inline void CopyInTile(uint32_t batch, uint32_t ti, uint32_t tj,
                                       uint32_t th, uint32_t tw, uint32_t alignW) {
        AscendC::LocalTensor<half> xL = inQueueX.AllocTensor<half>();
        for (uint32_t r = 0; r < th; r++) {
            uint64_t gmOff = ((uint64_t)batch * H + ti * origTileH + r) * W + tj * origTileW;
            xGm.SetGlobalBuffer(xAddr + gmOff, tw);
            AscendC::DataCopyPad(xL[r * alignW], xGm,
                {1, static_cast<uint16_t>(tw * sizeof(half)), 0, 0},
                {false, 0, 0, 0});
        }
        inQueueX.EnQue(xL);
    }

    __aicore__ inline void ComputeTile(uint32_t th, uint32_t tw, uint32_t alignW) {
        AscendC::LocalTensor<half> xL = inQueueX.DeQue<half>();
        AscendC::LocalTensor<half> yL = outQueueY.AllocTensor<half>();

        for (uint32_t r = 0; r < th; r++) {
            for (uint32_t c = 0; c < tw; c++) {
                yL.SetValue(c * origTileH + r, xL.GetValue(r * alignW + c));
            }
        }

        outQueueY.EnQue<half>(yL);
        inQueueX.FreeTensor(xL);
    }

    __aicore__ inline void CopyOutTile(uint32_t batch, uint32_t ti, uint32_t tj,
                                        uint32_t th, uint32_t tw) {
        AscendC::LocalTensor<half> yL = outQueueY.DeQue<half>();
        for (uint32_t c = 0; c < tw; c++) {
            uint64_t gmOff = ((uint64_t)batch * W + (tj * origTileW + c)) * H + ti * origTileH;
            yGm.SetGlobalBuffer(yAddr + gmOff, th);
            AscendC::DataCopyPad(yGm, yL[c * origTileH],
                {1, static_cast<uint16_t>(th * sizeof(half)), 0, 0});
        }
        outQueueY.FreeTensor(yL);
    }

private:
    AscendC::TPipe* pipe_;
    const __gm__ TransposeTilingData* tiling;
    __gm__ half* xAddr; __gm__ half* yAddr;
    AscendC::GlobalTensor<half> xGm; AscendC::GlobalTensor<half> yGm;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueX;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueY;
    uint32_t totalTiles; uint32_t startGlobalTile;
    uint32_t H; uint32_t W;
    uint32_t origTileH; uint32_t origTileW;
    uint32_t numTilesH; uint32_t numTilesW;
    uint32_t totalTilesPerBatch;
};

extern "C" __global__ __vector__ void transpose_kernel(GM_ADDR x, GM_ADDR y, GM_ADDR tiling)
{
    AscendC::TPipe pipe;
    KernelTranspose op(&pipe);
    op.Init(x, y, (__gm__ TransposeTilingData*)tiling);
    op.Process();
}
