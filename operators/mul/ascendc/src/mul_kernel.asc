#include "kernel_operator.h"
#include "mul_tiling.h"

class KernelMul {
public:
    __aicore__ inline KernelMul(AscendC::TPipe* pipe)
    {
        pipe_ = pipe;
    }

    __aicore__ inline void Init(GM_ADDR x1, GM_ADDR x2, GM_ADDR y,
                                const __gm__ MulTilingData* tiling)
    {
        this->tiling = tiling;
        uint32_t blockIdx = AscendC::GetBlockIdx();
        if (blockIdx >= tiling->blockNum) {
            total = 0;
            tileNum = 0;
            tailTileElementNum = 0;
            return;
        }
        if (blockIdx < tiling->blockNum - 1) {
            total = tiling->numPerCore;
            tileNum = total / TILE_LENGTH;
            tailTileElementNum = TILE_LENGTH;
        } else {
            total = tiling->tailNumLastCore;
            tileNum = (total + TILE_LENGTH - 1) / TILE_LENGTH;
            tailTileElementNum = total - TILE_LENGTH * (tileNum - 1);
        }

        x1Addr = (__gm__ half*)x1;
        x2Addr = (__gm__ half*)x2;
        yAddr = (__gm__ half*)y;
        blockOffset = blockIdx * tiling->numPerCore;

        pipe_->InitBuffer(inQueueX1, DOUBLE_BUFFER, TILE_LENGTH * sizeof(half));
        pipe_->InitBuffer(inQueueX2, DOUBLE_BUFFER, TILE_LENGTH * sizeof(half));
        pipe_->InitBuffer(outQueueY, DOUBLE_BUFFER, TILE_LENGTH * sizeof(half));
    }

    __aicore__ inline void Process()
    {
        if (total == 0) return;
        for (uint32_t i = 0; i < tileNum; i++) {
            uint32_t count = (i == tileNum - 1) ? tailTileElementNum : TILE_LENGTH;
            CopyIn(i, count);
            Compute(count);
            CopyOut(i, count);
        }
    }

    __aicore__ inline void CopyIn(uint32_t tileIdx, uint32_t count)
    {
        AscendC::LocalTensor<half> x1Local = inQueueX1.AllocTensor<half>();
        x1Gm.SetGlobalBuffer(x1Addr + blockOffset + tileIdx * TILE_LENGTH, count);
        AscendC::DataCopyPad(x1Local, x1Gm,
            {1, static_cast<uint16_t>(count * sizeof(half)), 0, 0},
            {false, 0, 0, 0});
        inQueueX1.EnQue(x1Local);

        AscendC::LocalTensor<half> x2Local = inQueueX2.AllocTensor<half>();
        x2Gm.SetGlobalBuffer(x2Addr + blockOffset + tileIdx * TILE_LENGTH, count);
        AscendC::DataCopyPad(x2Local, x2Gm,
            {1, static_cast<uint16_t>(count * sizeof(half)), 0, 0},
            {false, 0, 0, 0});
        inQueueX2.EnQue(x2Local);
    }

    __aicore__ inline void Compute(uint32_t count)
    {
        AscendC::LocalTensor<half> x1Local = inQueueX1.DeQue<half>();
        AscendC::LocalTensor<half> x2Local = inQueueX2.DeQue<half>();
        AscendC::LocalTensor<half> yLocal = outQueueY.AllocTensor<half>();
        AscendC::Mul(yLocal, x1Local, x2Local, count);
        outQueueY.EnQue<half>(yLocal);
        inQueueX1.FreeTensor(x1Local);
        inQueueX2.FreeTensor(x2Local);
    }

    __aicore__ inline void CopyOut(uint32_t tileIdx, uint32_t count)
    {
        AscendC::LocalTensor<half> yLocal = outQueueY.DeQue<half>();
        yGm.SetGlobalBuffer(yAddr + blockOffset + tileIdx * TILE_LENGTH, count);
        AscendC::DataCopyPad(yGm, yLocal,
            {1, static_cast<uint16_t>(count * sizeof(half)), 0, 0});
        outQueueY.FreeTensor(yLocal);
    }

private:
    AscendC::TPipe* pipe_;
    const __gm__ MulTilingData* tiling;
    __gm__ half* x1Addr;
    __gm__ half* x2Addr;
    __gm__ half* yAddr;
    uint32_t blockOffset;
    AscendC::GlobalTensor<half> x1Gm;
    AscendC::GlobalTensor<half> x2Gm;
    AscendC::GlobalTensor<half> yGm;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueX1;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueX2;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueY;
    uint32_t total;
    uint32_t tileNum;
    uint32_t tailTileElementNum;
};

extern "C" __global__ __vector__ void mul_kernel(GM_ADDR x1, GM_ADDR x2, GM_ADDR y, GM_ADDR tiling)
{
    AscendC::TPipe pipe;
    KernelMul op(&pipe);
    op.Init(x1, x2, y, (__gm__ MulTilingData*)tiling);
    op.Process();
}
