#include "kernel_operator.h"
#include "reduce_sum_tiling.h"

class KernelReduceSum {
public:
    __aicore__ inline KernelReduceSum(AscendC::TPipe* pipe) { pipe_ = pipe; }

    __aicore__ inline void Init(GM_ADDR x, GM_ADDR y,
                                const __gm__ ReduceSumTilingData* tiling)
    {
        this->tiling = tiling;
        uint32_t blockIdx = AscendC::GetBlockIdx();
        if (blockIdx >= tiling->blockNum) { totalRows = 0; return; }

        uint32_t rowsPerBlock = tiling->totalRows / tiling->blockNum;
        uint32_t remRows = tiling->totalRows - rowsPerBlock * tiling->blockNum;
        if (blockIdx < remRows) {
            startRow = blockIdx * (rowsPerBlock + 1);
            totalRows = rowsPerBlock + 1;
        } else {
            startRow = remRows * (rowsPerBlock + 1) + (blockIdx - remRows) * rowsPerBlock;
            totalRows = rowsPerBlock;
        }

        reduceLen = tiling->reduceLen;
        xAddr = (__gm__ half*)x;
        yAddr = (__gm__ half*)y;

        pipe_->InitBuffer(inQueueX, DOUBLE_BUFFER, reduceLen * sizeof(half));
        pipe_->InitBuffer(outQueueY, DOUBLE_BUFFER, 1 * sizeof(half));
        pipe_->InitBuffer(tmpBuf, reduceLen * sizeof(half));
    }

    __aicore__ inline void Process() {
        if (totalRows == 0) return;
        for (uint32_t i = 0; i < totalRows; i++) {
            uint32_t row = startRow + i;
            CopyIn(row);
            Compute();
            CopyOut(row);
        }
    }

    __aicore__ inline void CopyIn(uint32_t row) {
        AscendC::LocalTensor<half> xL = inQueueX.AllocTensor<half>();
        xGm.SetGlobalBuffer(xAddr + (uint64_t)row * reduceLen, reduceLen);
        AscendC::DataCopyPad(xL, xGm, {1, static_cast<uint16_t>(reduceLen * sizeof(half)), 0, 0}, {false, 0, 0, 0});
        inQueueX.EnQue(xL);
    }

    __aicore__ inline void Compute() {
        AscendC::LocalTensor<half> xL = inQueueX.DeQue<half>();
        AscendC::LocalTensor<half> rowResult = outQueueY.AllocTensor<half>();
        AscendC::LocalTensor<half> rTmp = tmpBuf.Get<half>();
        AscendC::ReduceSum<half>(rowResult, xL, rTmp, static_cast<int32_t>(reduceLen));
        outQueueY.EnQue<half>(rowResult);
        inQueueX.FreeTensor(xL);
    }

    __aicore__ inline void CopyOut(uint32_t row) {
        AscendC::LocalTensor<half> rowResult = outQueueY.DeQue<half>();
        yGm.SetGlobalBuffer(yAddr + row, 1);
        AscendC::DataCopyPad(yGm, rowResult, {1, static_cast<uint16_t>(sizeof(half)), 0, 0});
        outQueueY.FreeTensor(rowResult);
    }

private:
    AscendC::TPipe* pipe_;
    const __gm__ ReduceSumTilingData* tiling;
    __gm__ half* xAddr; __gm__ half* yAddr;
    AscendC::GlobalTensor<half> xGm; AscendC::GlobalTensor<half> yGm;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueX;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueY;
    AscendC::TBuf<AscendC::TPosition::VECCALC> tmpBuf;
    uint32_t totalRows; uint32_t startRow; uint32_t reduceLen;
};

extern "C" __global__ __vector__ void reduce_sum_kernel(GM_ADDR x, GM_ADDR y, GM_ADDR tiling) {
    AscendC::TPipe pipe; KernelReduceSum op(&pipe); op.Init(x, y, (__gm__ ReduceSumTilingData*)tiling); op.Process();
}
