#include "kernel_operator.h"
#include "reduce_sum_tiling.h"

using namespace AscendC;

class KernelReduceSumFP32 {
public:
    __aicore__ inline KernelReduceSumFP32(TPipe* pipe) { pipe_ = pipe; }

    __aicore__ inline void Init(GM_ADDR x, GM_ADDR y,
                                const __gm__ ReduceSumTilingData* tiling)
    {
        this->tiling = tiling;
        uint32_t blockIdx = AscendC::GetBlockIdx();
        if (blockIdx >= tiling->blockNum) { totalRows = 0; return; }

        uint32_t rowsPerBlock = tiling->totalRows / tiling->blockNum;
        uint32_t remRows = tiling->totalRows - rowsPerBlock * tiling->blockNum;
        startRow = blockIdx * rowsPerBlock + (blockIdx < remRows ? blockIdx : remRows);
        totalRows = rowsPerBlock + (blockIdx < remRows ? 1 : 0);

        reduceLen = tiling->reduceLen;
        xAddr = (__gm__ half*)x;
        yAddr = (__gm__ half*)y;

        pipe_->InitBuffer(inQueueX, DOUBLE_BUFFER, reduceLen * sizeof(half));
        pipe_->InitBuffer(inQueueF, DOUBLE_BUFFER, reduceLen * sizeof(float));
        pipe_->InitBuffer(sumBuf, DOUBLE_BUFFER, sizeof(float));
        pipe_->InitBuffer(tmpBuf, reduceLen * sizeof(float));
        pipe_->InitBuffer(outBuf, DOUBLE_BUFFER, sizeof(half));
    }

    __aicore__ inline void Process() {
        if (totalRows == 0) return;
        for (uint32_t i = 0; i < totalRows; i++) {
            uint32_t row = startRow + i;
            CopyIn(row);
            Compute();
            CopyOut(row);
        }
    }

    __aicore__ inline void CopyIn(uint32_t row) {
        LocalTensor<half> xL = inQueueX.AllocTensor<half>();
        xGm.SetGlobalBuffer(xAddr + (uint64_t)row * reduceLen, reduceLen);
        DataCopyPad(xL, xGm, {1, static_cast<uint16_t>(reduceLen * sizeof(half)), 0, 0}, {false, 0, 0, 0});
        inQueueX.EnQue(xL);
    }

    __aicore__ inline void Compute() {
        LocalTensor<half> xL = inQueueX.DeQue<half>();
        LocalTensor<float> xF = inQueueF.AllocTensor<float>();
        Cast(xF, xL, RoundMode::CAST_NONE, static_cast<int32_t>(reduceLen));
        inQueueX.FreeTensor(xL);

        LocalTensor<float> fTmp = tmpBuf.Get<float>();
        LocalTensor<float> sumF = sumBuf.AllocTensor<float>();
        ReduceSum<float>(sumF, xF, fTmp, static_cast<int32_t>(reduceLen));
        inQueueF.FreeTensor(xF);

        LocalTensor<half> resultH = outBuf.AllocTensor<half>();
        Cast(resultH, sumF, RoundMode::CAST_ROUND, 1);
        sumBuf.FreeTensor(sumF);
        outBuf.EnQue(resultH);
    }

    __aicore__ inline void CopyOut(uint32_t row) {
        LocalTensor<half> rowResult = outBuf.DeQue<half>();
        yGm.SetGlobalBuffer(yAddr + row, 1);
        DataCopyPad(yGm, rowResult, {1, static_cast<uint16_t>(sizeof(half)), 0, 0});
        outBuf.FreeTensor(rowResult);
    }

private:
    TPipe* pipe_;
    const __gm__ ReduceSumTilingData* tiling;
    __gm__ half* xAddr; __gm__ half* yAddr;
    AscendC::GlobalTensor<half> xGm; AscendC::GlobalTensor<half> yGm;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueX;
    AscendC::TQue<AscendC::TPosition::VECCALC, 1> inQueueF;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> sumBuf;
    AscendC::TBuf<AscendC::TPosition::VECCALC> tmpBuf;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outBuf;
    uint32_t totalRows; uint32_t startRow; uint32_t reduceLen;
};

extern "C" __global__ __vector__ void reduce_sum_fp32_kernel(GM_ADDR x, GM_ADDR y, GM_ADDR tiling) {
    AscendC::TPipe pipe;
    KernelReduceSumFP32 op(&pipe);
    op.Init(x, y, (__gm__ ReduceSumTilingData*)tiling);
    op.Process();
}
