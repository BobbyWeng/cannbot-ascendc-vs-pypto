#include <cstdint>
#include <iostream>
#include <vector>
#include <string>
#include <chrono>
#include <algorithm>
#include <cmath>
#include <cstring>
#include "acl/acl.h"
#include "reduce_sum_tiling.h"
#include "data_utils.h"
#include "reduce_sum_kernel.asc"

struct BenchResult { double median_us, mean_us, min_us, p90_us, std_us, cv; std::vector<double> latencies_us; };

BenchResult measure_kernel_only(uint32_t blockNum, aclrtStream stream,
    void *xDevice, void *outputDevice, void *tilingDevice, int warmup, int loops, int repeat)
{
    for (int i = 0; i < warmup; i++)
        reduce_sum_kernel<<<blockNum, nullptr, stream>>>((GM_ADDR)xDevice, (GM_ADDR)outputDevice, (GM_ADDR)tilingDevice);
    aclrtSynchronizeStream(stream);
    aclrtEvent start, stop; aclrtCreateEvent(&start); aclrtCreateEvent(&stop);
    std::vector<double> latencies;
    for (int r = 0; r < repeat; r++) {
        aclrtRecordEvent(start, stream);
        for (int i = 0; i < loops; i++)
            reduce_sum_kernel<<<blockNum, nullptr, stream>>>((GM_ADDR)xDevice, (GM_ADDR)outputDevice, (GM_ADDR)tilingDevice);
        aclrtRecordEvent(stop, stream); aclrtSynchronizeStream(stream);
        float elapsed_ms = 0.0f; aclrtEventElapsedTime(&elapsed_ms, start, stop);
        latencies.push_back(elapsed_ms * 1000.0 / loops);
    }
    aclrtDestroyEvent(start); aclrtDestroyEvent(stop);
    std::sort(latencies.begin(), latencies.end());
    BenchResult res; res.latencies_us = latencies; res.min_us = latencies.front(); res.median_us = latencies[latencies.size() / 2];
    res.p90_us = latencies[(size_t)(latencies.size() * 0.9)];
    double sum = 0; for (auto v : latencies) sum += v; res.mean_us = sum / latencies.size();
    double sq = 0; for (auto v : latencies) sq += (v - res.mean_us) * (v - res.mean_us); res.std_us = std::sqrt(sq / latencies.size()); res.cv = res.std_us / res.mean_us * 100.0;
    return res;
}

int run_batch(uint32_t batch, uint32_t blockDim,
    int32_t deviceId, int warmup, int loops, int repeat,
    const std::string &dataDir, const std::string &outputDir, const std::string &caseName)
{
    const uint32_t reduceLen = 384;
    uint64_t totalRows = (uint64_t)batch * 256;
    size_t inputByteSize = totalRows * reduceLen * sizeof(half);
    size_t outputByteSize = totalRows * sizeof(half);

    std::string xPath = dataDir + "/x_b" + std::to_string(batch) + "_" + caseName + ".bin";
    std::string outputPath = outputDir + "/output_b" + std::to_string(batch) + "_" + caseName + ".bin";

    uint32_t blockNum = blockDim;
    if (blockNum > totalRows) blockNum = (uint32_t)totalRows;
    if (blockNum == 0) blockNum = 1;

    ReduceSumTilingData tiling;
    tiling.blockNum = blockNum;
    tiling.totalRows = totalRows;
    tiling.reduceLen = reduceLen;

    uint8_t *tilingDevice = nullptr;
    aclrtMalloc((void**)&tilingDevice, sizeof(ReduceSumTilingData), ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMemcpy(tilingDevice, sizeof(ReduceSumTilingData), &tiling, sizeof(ReduceSumTilingData), ACL_MEMCPY_HOST_TO_DEVICE);

    void *xDevice = nullptr; void *outputDevice = nullptr;
    aclrtMalloc(&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc(&outputDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    uint8_t *hostBuf = new uint8_t[inputByteSize];
    ReadFile(xPath, inputByteSize, hostBuf, inputByteSize);
    aclrtMemcpy(xDevice, inputByteSize, hostBuf, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    delete[] hostBuf;

    aclrtStream stream; aclrtCreateStream(&stream);
    BenchResult res = measure_kernel_only(blockNum, stream, xDevice, outputDevice, tilingDevice, warmup, loops, repeat);

    hostBuf = new uint8_t[outputByteSize];
    aclrtMemcpy(hostBuf, outputByteSize, outputDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile(outputPath, hostBuf, outputByteSize); delete[] hostBuf;
    aclrtDestroyStream(stream); aclrtFree(xDevice); aclrtFree(outputDevice); aclrtFree(tilingDevice);

    printf("RESULT batch=%u case=%s blockNum=%u median_us=%.1f mean_us=%.1f min_us=%.1f p90_us=%.1f std_us=%.2f cv=%.2f\n",
        batch, caseName.c_str(), blockNum, res.median_us, res.mean_us, res.min_us, res.p90_us, res.std_us, res.cv);
    printf("RAW_LATENCIES:"); for (auto v : res.latencies_us) printf("%.1f,", v); printf("\n");
    return 0;
}

int32_t main(int32_t argc, char *argv[]) {
    aclInit(nullptr); int32_t deviceId = 0; if (argc > 1) deviceId = std::atoi(argv[1]);
    auto ret = aclrtSetDevice(deviceId);
    if (ret != ACL_SUCCESS) { printf("SetDevice failed=%d\n", ret); aclFinalize(); return ret; }
    uint32_t batch = 1; uint32_t blockDim = 20; int warmup = 100; int loops = 1000; int repeat = 10;
    std::string dataDir = "operators/reduce_sum/data";
    std::string outputDir = "operators/reduce_sum/ascendc/build/output";
    std::string caseName = "random_finite";
    if (argc > 2) batch = std::atoi(argv[2]); if (argc > 3) blockDim = std::atoi(argv[3]);
    if (argc > 4) warmup = std::atoi(argv[4]); if (argc > 5) loops = std::atoi(argv[5]); if (argc > 6) repeat = std::atoi(argv[6]);
    if (argc > 7) dataDir = argv[7]; if (argc > 8) outputDir = argv[8]; if (argc > 9) caseName = argv[9];
    run_batch(batch, blockDim, deviceId, warmup, loops, repeat, dataDir, outputDir, caseName);
    aclrtResetDevice(deviceId); aclFinalize(); return 0;
}
