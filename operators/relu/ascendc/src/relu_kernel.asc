#include "kernel_operator.h"
#include "relu_tiling.h"

class KernelRelu {
public:
    __aicore__ inline KernelRelu(AscendC::TPipe* pipe)
    {
        pipe_ = pipe;
    }

    __aicore__ inline void Init(GM_ADDR x, GM_ADDR y,
                                const __gm__ ReluTilingData* tiling)
    {
        this->tiling = tiling;
        uint32_t blockIdx = AscendC::GetBlockIdx();
        if (blockIdx >= tiling->blockNum) {
            total = 0;
            tileNum = 0;
            tailTileElementNum = 0;
            return;
        }
        if (blockIdx < tiling->blockNum - 1) {
            total = tiling->numPerCore;
            tileNum = total / TILE_LENGTH;
            tailTileElementNum = TILE_LENGTH;
        } else {
            total = tiling->tailNumLastCore;
            tileNum = (total + TILE_LENGTH - 1) / TILE_LENGTH;
            tailTileElementNum = total - TILE_LENGTH * (tileNum - 1);
        }

        xAddr = (__gm__ half*)x;
        yAddr = (__gm__ half*)y;
        blockOffset = blockIdx * tiling->numPerCore;

        pipe_->InitBuffer(inQueueX, DOUBLE_BUFFER, TILE_LENGTH * sizeof(half));
        pipe_->InitBuffer(outQueueY, DOUBLE_BUFFER, TILE_LENGTH * sizeof(half));
    }

    __aicore__ inline void Process()
    {
        if (total == 0) return;
        for (uint32_t i = 0; i < tileNum; i++) {
            uint32_t count = (i == tileNum - 1) ? tailTileElementNum : TILE_LENGTH;
            CopyIn(i, count);
            Compute(count);
            CopyOut(i, count);
        }
    }

    __aicore__ inline void CopyIn(uint32_t tileIdx, uint32_t count)
    {
        AscendC::LocalTensor<half> xLocal = inQueueX.AllocTensor<half>();
        xGm.SetGlobalBuffer(xAddr + blockOffset + tileIdx * TILE_LENGTH, count);
        AscendC::DataCopyPad(xLocal, xGm,
            {1, static_cast<uint16_t>(count * sizeof(half)), 0, 0},
            {false, 0, 0, 0});
        inQueueX.EnQue(xLocal);
    }

    __aicore__ inline void Compute(uint32_t count)
    {
        AscendC::LocalTensor<half> xLocal = inQueueX.DeQue<half>();
        AscendC::LocalTensor<half> yLocal = outQueueY.AllocTensor<half>();
        AscendC::Relu(yLocal, xLocal, count);
        outQueueY.EnQue<half>(yLocal);
        inQueueX.FreeTensor(xLocal);
    }

    __aicore__ inline void CopyOut(uint32_t tileIdx, uint32_t count)
    {
        AscendC::LocalTensor<half> yLocal = outQueueY.DeQue<half>();
        yGm.SetGlobalBuffer(yAddr + blockOffset + tileIdx * TILE_LENGTH, count);
        AscendC::DataCopyPad(yGm, yLocal,
            {1, static_cast<uint16_t>(count * sizeof(half)), 0, 0});
        outQueueY.FreeTensor(yLocal);
    }

private:
    AscendC::TPipe* pipe_;
    const __gm__ ReluTilingData* tiling;
    __gm__ half* xAddr;
    __gm__ half* yAddr;
    uint32_t blockOffset;
    AscendC::GlobalTensor<half> xGm;
    AscendC::GlobalTensor<half> yGm;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueX;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueY;
    uint32_t total;
    uint32_t tileNum;
    uint32_t tailTileElementNum;
};

extern "C" __global__ __vector__ void relu_kernel(GM_ADDR x, GM_ADDR y, GM_ADDR tiling)
{
    AscendC::TPipe pipe;
    KernelRelu op(&pipe);
    op.Init(x, y, (__gm__ ReluTilingData*)tiling);
    op.Process();
}
