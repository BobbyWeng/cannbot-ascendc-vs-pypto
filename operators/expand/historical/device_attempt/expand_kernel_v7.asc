#include "kernel_operator.h"
#include "expand_tiling.h"

class KernelExpand {
public:
    __aicore__ inline KernelExpand(AscendC::TPipe* pipe) { pipe_ = pipe; }

    __aicore__ inline void Init(GM_ADDR x, GM_ADDR y,
                                const __gm__ ExpandTilingData* tiling)
    {
        this->tiling = tiling;
        uint32_t blockIdx = AscendC::GetBlockIdx();
        if (blockIdx >= tiling->blockNum) {
            start = tiling->totalOutputElements;
            end = tiling->totalOutputElements;
            return;
        }
        uint64_t outPerCore = tiling->totalOutputElements / tiling->blockNum;
        start = blockIdx * outPerCore;
        end = (blockIdx < tiling->blockNum - 1)
            ? (blockIdx + 1) * outPerCore
            : tiling->totalOutputElements;

        xAddr = (__gm__ half*)x;
        yAddr = (__gm__ half*)y;
        inRowElems = tiling->inputRowElems;
        expandF = tiling->expandFactor;
        batchOutSize = inRowElems * expandF;

        pipe_->InitBuffer(inQueueX, DOUBLE_BUFFER, 256 * sizeof(half));
        pipe_->InitBuffer(outQueueY, DOUBLE_BUFFER, inRowElems * expandF * sizeof(half));
    }

    __aicore__ inline void Process()
    {
        if (start >= end) return;

        uint64_t pos = start;
        while (pos < end) {
            uint64_t batchIdx = pos / batchOutSize;
            uint64_t localPos = pos % batchOutSize;
            uint32_t rowInBatch = localPos / expandF;
            uint64_t rowStartOut = batchIdx * batchOutSize + rowInBatch * expandF;

            AscendC::LocalTensor<half> xLocal = inQueueX.AllocTensor<half>();
            xGm.SetGlobalBuffer(xAddr + batchIdx * inRowElems, inRowElems);
            AscendC::DataCopy(xLocal, xGm, inRowElems);

            AscendC::LocalTensor<half> yLocal = outQueueY.AllocTensor<half>();

            for (uint32_t i = 0; i < inRowElems; i++) {
                half* ubPtr = (half*)((uintptr_t)xLocal.GetPhyAddr() + i * sizeof(half));
                half val = *ubPtr;
                for (uint32_t j = 0; j < expandF; j++) {
                    half* yPtr = (half*)((uintptr_t)yLocal.GetPhyAddr() + (i * expandF + j) * sizeof(half));
                    *yPtr = val;
                }
            }

            yGm.SetGlobalBuffer(yAddr + rowStartOut, batchOutSize);
            AscendC::DataCopyPad(yGm, yLocal,
                {1, static_cast<uint16_t>(batchOutSize * sizeof(half)), 0, 0});

            inQueueX.FreeTensor(xLocal);
            outQueueY.FreeTensor(yLocal);
            pos = rowStartOut + batchOutSize;
        }
    }

private:
    AscendC::TPipe* pipe_;
    const __gm__ ExpandTilingData* tiling;
    __gm__ half* xAddr;
    __gm__ half* yAddr;
    AscendC::GlobalTensor<half> xGm;
    AscendC::GlobalTensor<half> yGm;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueX;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueY;
    uint64_t start, end;
    uint32_t inRowElems, expandF, batchOutSize;
};

extern "C" __global__ __vector__ void expand_kernel(GM_ADDR x, GM_ADDR y, GM_ADDR tiling)
{
    AscendC::TPipe pipe;
    KernelExpand op(&pipe);
    op.Init(x, y, (__gm__ ExpandTilingData*)tiling);
    op.Process();
}
