@pypto.frontend.jit
def expand_row(x: pypto.Tensor([1], pypto.DT_FP16),
               y: pypto.Tensor([384], pypto.DT_FP16)):
    pypto.set_vec_tile_shapes(128, 1024)
    y.move(pypto.op.expand_clone(x, [384]))

