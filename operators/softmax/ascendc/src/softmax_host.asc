#include <cstdint>
#include <iostream>
#include <vector>
#include <string>
#include <algorithm>
#include <cmath>
#include <cstring>
#include "acl/acl.h"
#include "softmax_tiling.h"
#include "data_utils.h"

struct BenchRes {
    double med, mean, min, p90, std;
    std::vector<double> lats;
};

#include "softmax_kernel.asc"

BenchRes measure(uint32_t bn, aclrtStream s, void* in, void* out, void* t, int w, int l, int r)
{
    for (int i = 0; i < w; i++)
        softmax_kernel<<<bn, nullptr, s>>>((GM_ADDR)in, (GM_ADDR)out, (GM_ADDR)t);
    aclrtSynchronizeStream(s);

    aclrtEvent st, en;
    aclrtCreateEvent(&st); aclrtCreateEvent(&en);
    std::vector<double> lv;
    for (int i = 0; i < r; i++) {
        aclrtRecordEvent(st, s);
        for (int j = 0; j < l; j++)
            softmax_kernel<<<bn, nullptr, s>>>((GM_ADDR)in, (GM_ADDR)out, (GM_ADDR)t);
        aclrtRecordEvent(en, s); aclrtSynchronizeStream(s);
        float ms = 0; aclrtEventElapsedTime(&ms, st, en);
        lv.push_back(ms * 1000.0 / l);
    }
    aclrtDestroyEvent(st); aclrtDestroyEvent(en);

    std::sort(lv.begin(), lv.end());
    BenchRes res; res.lats = lv; res.min = lv.front(); res.med = lv[lv.size() / 2];
    res.p90 = lv[(size_t)(lv.size() * 0.9)];
    double sum = 0; for (auto v : lv) sum += v; res.mean = sum / lv.size();
    double sq = 0; for (auto v : lv) sq += (v - res.mean) * (v - res.mean); res.std = std::sqrt(sq / lv.size());
    return res;
}

int run(uint32_t batch, uint32_t bd, int did, int w, int l, int r, const std::string& dd, const std::string& od)
{
    uint32_t ld = 32, totalRows = batch * 256, bn = bd;
    if (bn > totalRows) bn = totalRows; if (bn == 0) bn = 1;
    uint32_t rpb = (totalRows + bn - 1) / bn;
    const uint32_t MAX = 255;
    while (rpb > MAX) { bn++; rpb = (totalRows + bn - 1) / bn; }

    SoftmaxTilingData t;
    t.blockNum = bn; t.rowsPerBlock = rpb;
    t.tailRows = totalRows - rpb * (bn - 1);
    t.lastDimSize = ld; t.lastDimSizeF = (float)ld;

    size_t bs = (size_t)batch * 256 * 32 * sizeof(half);
    uint8_t* td = nullptr;
    aclrtMalloc((void**)&td, sizeof(SoftmaxTilingData), ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMemcpy(td, sizeof(SoftmaxTilingData), &t, sizeof(SoftmaxTilingData), ACL_MEMCPY_HOST_TO_DEVICE);

    void* in = nullptr; void* out = nullptr;
    aclrtMalloc(&in, bs, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc(&out, bs, ACL_MEM_MALLOC_HUGE_FIRST);

    std::string ip = dd + "/input_b" + std::to_string(batch) + "_fp16.bin";
    std::string op = od + "/output_b" + std::to_string(batch) + ".bin";

    uint8_t* hb = new uint8_t[bs];
    ReadFile(ip, bs, hb, bs);
    aclrtMemcpy(in, bs, hb, bs, ACL_MEMCPY_HOST_TO_DEVICE);
    delete[] hb;

    aclrtStream stream;
    aclrtCreateStream(&stream);

    BenchRes res = measure(bn, stream, in, out, td, w, l, r);

    hb = new uint8_t[bs];
    aclrtMemcpy(hb, bs, out, bs, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile(op, hb, bs);
    delete[] hb;

    aclrtDestroyStream(stream);
    aclrtFree(in); aclrtFree(out); aclrtFree(td);

    double bw = (double)bs * 2 / res.med / 1e3;
    printf("RESULT batch=%u blockDim=%u median_us=%.1f mean_us=%.1f min_us=%.1f p90_us=%.1f std_us=%.2f bw=%.3f\n",
        batch, bn, res.med, res.mean, res.min, res.p90, res.std, bw);
    printf("RAW_LATENCIES:");
    for (size_t i = 0; i < res.lats.size(); i++) {
        if (i > 0) printf(",");
        printf("%.1f", res.lats[i]);
    }
    printf("\n");
    return 0;
}

int32_t main(int32_t argc, char* argv[])
{
    aclInit(nullptr);
    int32_t did = 0; if (argc > 1) did = std::atoi(argv[1]);
    auto ret = aclrtSetDevice(did);
    if (ret != ACL_SUCCESS) { printf("aclrtSetDevice failed\n"); aclFinalize(); return ret; }

    uint32_t batch = 1, bd = 20;
    int w = 200, l = 100, r = 5;
    std::string dd = "operators/softmax/data", od = "operators/softmax/ascendc/build/output";

    if (argc > 2) batch = std::atoi(argv[2]);
    if (argc > 3) bd = std::atoi(argv[3]);
    if (argc > 4) w = std::atoi(argv[4]);
    if (argc > 5) l = std::atoi(argv[5]);
    if (argc > 6) r = std::atoi(argv[6]);
    if (argc > 7) dd = argv[7];
    if (argc > 8) od = argv[8];

    run(batch, bd, did, w, l, r, dd, od);
    aclrtResetDevice(did); aclFinalize();
    return 0;
}
