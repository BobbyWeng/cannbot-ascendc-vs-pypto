#include "kernel_operator.h"
#include "where_tiling.h"

using namespace AscendC;

class KernelWhere {
public:
    __aicore__ inline KernelWhere(TPipe* pipe)
    {
        pipe_ = pipe;
    }

    __aicore__ inline void Init(GM_ADDR condition, GM_ADDR x1, GM_ADDR x2, GM_ADDR y,
                                const __gm__ WhereTilingData* tiling)
    {
        this->tiling = tiling;
        uint32_t blockIdx = GetBlockIdx();
        if (blockIdx >= tiling->blockNum) {
            total = 0;
            tileNum = 0;
            tailTileElementNum = 0;
            return;
        }
        if (blockIdx < tiling->blockNum - 1) {
            total = tiling->numPerCore;
            tileNum = total / TILE_LENGTH;
            tailTileElementNum = TILE_LENGTH;
        } else {
            total = tiling->tailNumLastCore;
            tileNum = (total + TILE_LENGTH - 1) / TILE_LENGTH;
            tailTileElementNum = total - TILE_LENGTH * (tileNum - 1);
        }

        condAddr = (__gm__ uint8_t*)condition;
        x1Addr = (__gm__ half*)x1;
        x2Addr = (__gm__ half*)x2;
        yAddr = (__gm__ half*)y;
        blockOffset = blockIdx * tiling->numPerCore;

        pipe_->InitBuffer(inQueueCond, DOUBLE_BUFFER, TILE_LENGTH * sizeof(uint8_t));
        pipe_->InitBuffer(inQueueX1, DOUBLE_BUFFER, TILE_LENGTH * sizeof(half));
        pipe_->InitBuffer(inQueueX2, DOUBLE_BUFFER, TILE_LENGTH * sizeof(half));
        pipe_->InitBuffer(outQueueY, DOUBLE_BUFFER, TILE_LENGTH * sizeof(half));
    }

    __aicore__ inline void Process()
    {
        if (total == 0) return;
        for (uint32_t i = 0; i < tileNum; i++) {
            uint32_t count = (i == tileNum - 1) ? tailTileElementNum : TILE_LENGTH;
            CopyIn(i, count);
            Compute(count);
            CopyOut(i, count);
        }
    }

    __aicore__ inline void CopyIn(uint32_t tileIdx, uint32_t count)
    {
        auto condLocal = inQueueCond.AllocTensor<uint8_t>();
        condGm.SetGlobalBuffer(condAddr + blockOffset + tileIdx * TILE_LENGTH, count);
        DataCopyPad(condLocal, condGm,
            {1, static_cast<uint16_t>(count * sizeof(uint8_t)), 0, 0},
            {false, 0, 0, 0});
        inQueueCond.EnQue(condLocal);

        auto x1Local = inQueueX1.AllocTensor<half>();
        x1Gm.SetGlobalBuffer(x1Addr + blockOffset + tileIdx * TILE_LENGTH, count);
        DataCopyPad(x1Local, x1Gm,
            {1, static_cast<uint16_t>(count * sizeof(half)), 0, 0},
            {false, 0, 0, 0});
        inQueueX1.EnQue(x1Local);

        auto x2Local = inQueueX2.AllocTensor<half>();
        x2Gm.SetGlobalBuffer(x2Addr + blockOffset + tileIdx * TILE_LENGTH, count);
        DataCopyPad(x2Local, x2Gm,
            {1, static_cast<uint16_t>(count * sizeof(half)), 0, 0},
            {false, 0, 0, 0});
        inQueueX2.EnQue(x2Local);
    }

    __aicore__ inline void Compute(uint32_t count)
    {
        LocalTensor<uint8_t> condLocal = inQueueCond.DeQue<uint8_t>();
        LocalTensor<half> x1Local = inQueueX1.DeQue<half>();
        LocalTensor<half> x2Local = inQueueX2.DeQue<half>();
        LocalTensor<half> yLocal = outQueueY.AllocTensor<half>();

        // Approach: Cast cond from uint8 to half, then scalar select
        // Cast(uint8 → half, CAST_NONE): 0→0.0, 1→1.0
        Cast(yLocal, condLocal, RoundMode::CAST_NONE, count);
        // yLocal now has: 0.0h for false condition, 1.0h for true condition
        
        // Now for each element: if cond[i] != 0, pick x1[i], else x2[i]
        // Use float for comparison to avoid half precision operation errors
        for (uint32_t i = 0; i < count; i++) {
            float condVal = static_cast<float>(yLocal.GetValue(i));
            half x1Val = x1Local.GetValue(i);
            half x2Val = x2Local.GetValue(i);
            half result;
            if (condVal != 0.0f) {
                result = x1Val;
            } else {
                result = x2Val;
            }
            yLocal.SetValue(i, result);
        }

        outQueueY.EnQue<half>(yLocal);
        inQueueCond.FreeTensor(condLocal);
        inQueueX1.FreeTensor(x1Local);
        inQueueX2.FreeTensor(x2Local);
    }

    __aicore__ inline void CopyOut(uint32_t tileIdx, uint32_t count)
    {
        LocalTensor<half> yLocal = outQueueY.DeQue<half>();
        yGm.SetGlobalBuffer(yAddr + blockOffset + tileIdx * TILE_LENGTH, count);
        DataCopyPad(yGm, yLocal,
            {1, static_cast<uint16_t>(count * sizeof(half)), 0, 0});
        outQueueY.FreeTensor(yLocal);
    }

private:
    TPipe* pipe_;
    const __gm__ WhereTilingData* tiling;
    __gm__ uint8_t* condAddr;
    __gm__ half* x1Addr;
    __gm__ half* x2Addr;
    __gm__ half* yAddr;
    uint32_t blockOffset;
    GlobalTensor<uint8_t> condGm;
    GlobalTensor<half> x1Gm;
    GlobalTensor<half> x2Gm;
    GlobalTensor<half> yGm;
    TQue<TPosition::VECIN, 1> inQueueCond;
    TQue<TPosition::VECIN, 1> inQueueX1;
    TQue<TPosition::VECIN, 1> inQueueX2;
    TQue<TPosition::VECOUT, 1> outQueueY;
    TBuf<TPosition::VECCALC> tmpBuf;
    uint32_t total;
    uint32_t tileNum;
    uint32_t tailTileElementNum;
};

extern "C" __global__ __vector__ void where_kernel(GM_ADDR condition, GM_ADDR x1, GM_ADDR x2, GM_ADDR y, GM_ADDR tiling)
{
    TPipe pipe;
    KernelWhere op(&pipe);
    op.Init(condition, x1, x2, y, (__gm__ WhereTilingData*)tiling);
    op.Process();
}
