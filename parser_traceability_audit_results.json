  "parser_audit": {
    "file": "common/profiler/parse_profiler.py",
    "lines": 145,
    "bugs": [
      {
        "id": "BUG-1",
        "severity": "high",
        "title": "primary_compute_kernel_us = max single kernel across ALL iterations, not per-call",
        "location": "line 61",
        "detail": "Selects max dur from all kernel events in all 100 iterations. This is the absolute worst-case kernel from the entire profiling session, not a representative per-call metric.",
        "impact": "Value is inflated by any outlier iteration with a long single kernel."
      },
      {
        "id": "BUG-2",
        "severity": "critical",
        "title": "No per-call primary compute kernel metric",
        "location": "lines 72-94",
        "detail": "The parser computes kernel_type_breakdown[X]['per_call_us'] = total_us / loops, which is the SUM of all kernel events of that type per call, not the primary (max) kernel duration. There is no field for primary_compute_kernel_us / loops.",
        "impact": "Final reports for add incorrectly use per_call_us as the primary_compute_kernel_us for PyPTO (136.03 vs 132.123 for b1)."
      },
      {
        "id": "BUG-3",
        "severity": "high",
        "title": "No raw statistics (min, median, P90, std, CV) from msprof trace",
        "location": "lines 72-94",
        "detail": "Only mean_us is extracted per kernel type. No distribution statistics. This contrasts with the host-side Ascend C benchmark binary which outputs median/min/p90/std/CV.",
        "impact": "Cannot assess kernel duration variance from msprof parsed data."
      },
      {
        "id": "BUG-4",
        "severity": "medium",
        "title": "kernels_per_logical_call = total_kernels / loops — includes AICPU events",
        "location": "line 69",
        "detail": "The denominator is all kernel events including AICPU executor events. For PyPTO with 2 AICPU + 1 MIX_AIC per call, this gives 3.01, which includes non-compute executors.",
        "impact": "Misleading for compute kernel comparison."
      },
      {
        "id": "BUG-5",
        "severity": "low",
        "title": "AICPU filtering via substring check",
        "location": "line 59",
        "detail": "'AICPU' not in e['type'] — substring match. A kernel named 'KERNEL_MY_AICPU_CUSTOM' would be misclassified as AICPU.",
        "impact": "Low risk with current kernel naming, but fragile."
      },
      {
        "id": "BUG-6",
        "severity": "medium",
        "title": "AICPU-only fallback selects executor as primary compute",
        "location": "lines 62-63",
        "detail": "If all kernel events are AICPU (no compute kernels found), the max AICPU executor becomes the 'primary compute kernel.'",
        "impact": "Would silently misrepresent the compute kernel. Verify CONFIRMED in expand pypto parsed data."
      },
      {
        "id": "BUG-7",
        "severity": "critical",
        "title": "No provenance tracking (source hash, raw dir hash, parser version)",
        "location": "lines 72-101",
        "detail": "The parser output contains no fields identifying: which PROF_* directory was parsed, the SHA256 of the raw msprof JSON, the SHA256 of the kernel binary, or the parser version.",
        "impact": "ZERO traceability from parsed data back to the source binary. Cannot verify which profiling run produced the data."
      },
      {
        "id": "BUG-8",
        "severity": "high",
        "title": "--loops parameter is caller-trusted with no validation",
        "location": "line 111, 69-70",
        "detail": "Default loops=100. The caller passes this value. If the caller is wrong (e.g., profiled 50 iterations but passes --loops 100), all per-call metrics are off by 2x. No cross-check against kernel_count.",
        "impact": "Silent data corruption if the parameter is wrong."
      },
      {
        "id": "BUG-9",
        "severity": "low",
        "title": "Mult-kernel operators: single primary_compute_kernel_us hides second kernel type",
        "location": "lines 58-63",
        "detail": "Only the single max kernel event is reported as primary. For multi-kernel operators where a second kernel type contributes significant total time, this is misleading.",
        "impact": "Partial picture for multi-kernel operators."
      }
    ],
    "functionality": {
      "find_prof_dir": "Picks first PROF_* directory in reverse sorted order (most recent). Correct.",
      "find_task_time_csv": "Searches for task_time*.csv. Never actually used by parse_profiler.py. Dead code.",
      "find_trace_file": "Searches for msprof_*.json. Correctly finds the Chrome trace file.",
      "parse_trace_json": "Parses Chrome trace format. Filters for ph='X' (complete events). Uses Task Type arg for kernel classification.",
      "aggregate_device_kernels": "In profiler_utils.py. Alternative parser that operates on raw event lists. Has logical_call_marker filtering. Not used by parse_profiler.py."
    }
  },
